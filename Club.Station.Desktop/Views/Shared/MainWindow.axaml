<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:rxui="http://reactiveui.net"
        xmlns:shared="clr-namespace:Club.Station.Desktop.Views.Shared"
        xmlns:security="clr-namespace:Club.Station.Desktop.Views.Security"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="Club.Station.Desktop.Views.Shared.MainWindow"
        Icon="/Assets/avalonia-logo.ico"
        Title="Nubia Club Station"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen">

    <Grid RowDefinitions="Auto,*,35" ColumnDefinitions="*">
        <Panel Grid.Row="0">
            <shared:MainMenu/>
        </Panel>
        <Panel Grid.Row="1">
            <rxui:RoutedViewHost 
                Router="{Binding Router}"
                HorizontalContentAlignment="Stretch"
                VerticalContentAlignment="Stretch"
                >
                <rxui:RoutedViewHost.DefaultContent>
                    <security:LoginScreenView HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </rxui:RoutedViewHost.DefaultContent>
            </rxui:RoutedViewHost>
        </Panel>
        <Panel Grid.Row="2" Background="gray"/>
    </Grid>
</Window>
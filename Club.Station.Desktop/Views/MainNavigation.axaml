<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="Club.Station.Desktop.Views.MainNavigation">
    
    <StackPanel>
        <Button x:Name="UserManagementButton" Command="{Binding GoToUserManagement }">
            Users
        </Button>
        <Button x:Name="MemberManagementButton" Command="{Binding GoToMemberManagement }">
            Members
        </Button>
        <Button x:Name="GroupManagementButton" Command="{Binding GoToGroupManagement }">
            Groups
        </Button>
        <Button x:Name="EventManagementButton" Command="{Binding GoToEventManagement }">
            Events
        </Button>
        <Button x:Name="FinancesManagementButton" Command="{Binding GoToFinancesManagement }">
            Finances
        </Button>
    </StackPanel>
</UserControl>

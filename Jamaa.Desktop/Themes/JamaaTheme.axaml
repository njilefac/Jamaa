<ResourceDictionary xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ResourceDictionary.MergedDictionaries>
        <ResourceInclude Source="/Assets/Resources/Icons.axaml" />
    </ResourceDictionary.MergedDictionaries>

    <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Light">
            <Color x:Key="JamaaPrimaryColor">#2563EB</Color>
            <Color x:Key="JamaaSecondaryColor">#3B82F6</Color>
            <Color x:Key="JamaaAccentColor">#2563EB</Color>

            <!--  System Accent Overrides  -->
            <Color x:Key="SystemAccentColor">#2563EB</Color>
            <Color x:Key="SystemAccentColorLight1">#3B82F6</Color>
            <Color x:Key="SystemAccentColorLight2">#60A5FA</Color>
            <Color x:Key="SystemAccentColorLight3">#93C5FD</Color>
            <Color x:Key="SystemAccentColorDark1">#1D4ED8</Color>
            <Color x:Key="SystemAccentColorDark2">#1E40AF</Color>
            <Color x:Key="SystemAccentColorDark3">#1E3A8A</Color>

            <SolidColorBrush Color="{StaticResource JamaaPrimaryColor}" x:Key="JamaaPrimaryBrush" />
            <SolidColorBrush Color="{StaticResource JamaaAccentColor}" x:Key="JamaaAccentBrush" />

            <!--  Backgrounds  -->
            <SolidColorBrush Color="#F1F5F9" x:Key="AppBackgroundColor" />
            <SolidColorBrush Color="#FFFFFF" x:Key="AppSurfaceColor" />
            <SolidColorBrush Color="#F8FAFC" x:Key="AppHeaderBackground" />
            <SolidColorBrush Color="#FFFFFF" x:Key="AppCardBackground" />
            <SolidColorBrush Color="#E2E8F0" x:Key="AppLayerBackground" />

            <!--  Borders & Dividers  -->
            <SolidColorBrush Color="#CBD5E1" x:Key="AppBorderColor" />
            <SolidColorBrush Color="#E2E8F0" x:Key="AppDividerColor" />

            <!--  Text  -->
            <SolidColorBrush Color="#0F172A" x:Key="AppTextPrimary" />
            <SolidColorBrush Color="#475569" x:Key="AppTextSecondary" />
            <SolidColorBrush Color="#94A3B8" x:Key="AppTextDisabled" />

            <!--  Dashboard Semantic Colors  -->
            <SolidColorBrush Color="#DBEAFE" x:Key="DashboardAccentSurfaceBrush" />
            <SolidColorBrush Color="#1D4ED8" x:Key="DashboardAccentForegroundBrush" />
            <SolidColorBrush Color="#DBEAFE" x:Key="DashboardHeaderActionBackgroundBrush" />
            <SolidColorBrush Color="#1E3A8A" x:Key="DashboardHeaderActionForegroundBrush" />
            <SolidColorBrush Color="#BFDBFE" x:Key="DashboardHeaderActionHoverBackgroundBrush" />
            <SolidColorBrush Color="#DCFCE7" x:Key="DashboardSuccessSurfaceBrush" />
            <SolidColorBrush Color="#15803D" x:Key="DashboardSuccessForegroundBrush" />
            <SolidColorBrush Color="#FEF3C7" x:Key="DashboardWarningSurfaceBrush" />
            <SolidColorBrush Color="#B45309" x:Key="DashboardWarningForegroundBrush" />
            <SolidColorBrush Color="#FEE2E2" x:Key="DashboardDangerSurfaceBrush" />
            <SolidColorBrush Color="#B91C1C" x:Key="DashboardDangerForegroundBrush" />
            <SolidColorBrush Color="#E0F2FE" x:Key="DashboardInfoSurfaceBrush" />
            <SolidColorBrush Color="#1D4ED8" x:Key="DashboardInfoForegroundBrush" />

            <!--  Validation  -->
            <SolidColorBrush Color="#FEF2F2" x:Key="ValidationErrorBackground" />
            <SolidColorBrush Color="#EF4444" x:Key="ValidationErrorBrush" />
            <SolidColorBrush Color="#991B1B" x:Key="ValidationErrorForeground" />
        </ResourceDictionary>
        <ResourceDictionary x:Key="Dark">
            <Color x:Key="JamaaPrimaryColor">#479EF5</Color>
            <Color x:Key="JamaaSecondaryColor">#67AFE8</Color>
            <Color x:Key="JamaaAccentColor">#479EF5</Color>

            <!--  System Accent Overrides  -->
            <Color x:Key="SystemAccentColor">#479EF5</Color>
            <Color x:Key="SystemAccentColorLight1">#67AFE8</Color>
            <Color x:Key="SystemAccentColorLight2">#87C1F2</Color>
            <Color x:Key="SystemAccentColorLight3">#A7D2F5</Color>
            <Color x:Key="SystemAccentColorDark1">#2E88D8</Color>
            <Color x:Key="SystemAccentColorDark2">#1572BC</Color>
            <Color x:Key="SystemAccentColorDark3">#005C9F</Color>

            <SolidColorBrush Color="{StaticResource JamaaPrimaryColor}" x:Key="JamaaPrimaryBrush" />
            <SolidColorBrush Color="{StaticResource JamaaAccentColor}" x:Key="JamaaAccentBrush" />

            <!--  Backgrounds  -->
            <SolidColorBrush Color="#202020" x:Key="AppBackgroundColor" />
            <SolidColorBrush Color="#2B2B2B" x:Key="AppSurfaceColor" />
            <SolidColorBrush Color="#252525" x:Key="AppHeaderBackground" />
            <SolidColorBrush Color="#2C2C2C" x:Key="AppCardBackground" />
            <SolidColorBrush Color="#1C1C1C" x:Key="AppLayerBackground" />

            <!--  Borders & Dividers  -->
            <SolidColorBrush Color="#3E3E3E" x:Key="AppBorderColor" />
            <SolidColorBrush Color="#323232" x:Key="AppDividerColor" />

            <!--  Text  -->
            <SolidColorBrush Color="#FFFFFF" x:Key="AppTextPrimary" />
            <SolidColorBrush Color="#D2D0CE" x:Key="AppTextSecondary" />
            <SolidColorBrush Color="#484644" x:Key="AppTextDisabled" />

            <!--  Dashboard Semantic Colors  -->
            <SolidColorBrush Color="#1E3A8A" x:Key="DashboardAccentSurfaceBrush" />
            <SolidColorBrush Color="#BFDBFE" x:Key="DashboardAccentForegroundBrush" />
            <SolidColorBrush Color="#1E3A8A" x:Key="DashboardHeaderActionBackgroundBrush" />
            <SolidColorBrush Color="#EFF6FF" x:Key="DashboardHeaderActionForegroundBrush" />
            <SolidColorBrush Color="#1572BC" x:Key="DashboardHeaderActionHoverBackgroundBrush" />
            <SolidColorBrush Color="#14532D" x:Key="DashboardSuccessSurfaceBrush" />
            <SolidColorBrush Color="#BBF7D0" x:Key="DashboardSuccessForegroundBrush" />
            <SolidColorBrush Color="#78350F" x:Key="DashboardWarningSurfaceBrush" />
            <SolidColorBrush Color="#FDE68A" x:Key="DashboardWarningForegroundBrush" />
            <SolidColorBrush Color="#7F1D1D" x:Key="DashboardDangerSurfaceBrush" />
            <SolidColorBrush Color="#FECACA" x:Key="DashboardDangerForegroundBrush" />
            <SolidColorBrush Color="#0C4A6E" x:Key="DashboardInfoSurfaceBrush" />
            <SolidColorBrush Color="#BAE6FD" x:Key="DashboardInfoForegroundBrush" />

            <!--  Validation  -->
            <SolidColorBrush Color="#442726" x:Key="ValidationErrorBackground" />
            <SolidColorBrush Color="#F1707B" x:Key="ValidationErrorBrush" />
            <SolidColorBrush Color="#FFFFFF" x:Key="ValidationErrorForeground" />
        </ResourceDictionary>
    </ResourceDictionary.ThemeDictionaries>

    <!--  Standard Fluent-like Corner Radii  -->
    <CornerRadius x:Key="ControlCornerRadius">4</CornerRadius>
    <CornerRadius x:Key="OverlayCornerRadius">8</CornerRadius>
    <CornerRadius x:Key="CardCornerRadius">6</CornerRadius>

    <!--  Standard Fluent-like Spacings  -->
    <Thickness x:Key="StandardPadding">12</Thickness>
    <Thickness x:Key="CardPadding">16</Thickness>
    <Thickness x:Key="SectionMargin">0,0,0,24</Thickness>

</ResourceDictionary>
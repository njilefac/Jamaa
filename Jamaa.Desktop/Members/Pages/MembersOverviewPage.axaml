<UserControl
    HorizontalAlignment="Stretch"
    Padding="5,5,15,5"
    VerticalAlignment="Stretch"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d"
    x:Class="Jamaa.Desktop.Members.Pages.MembersOverviewPage"
    x:DataType="pages:MembersOverviewViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Jamaa.Desktop.Services.Navigation.Models"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:pages="clr-namespace:Jamaa.Desktop.Members.Pages"
    xmlns:u="https://irihi.tech/ursa"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid ColumnDefinitions="*" RowDefinitions="Auto,*">
        <u:Breadcrumb
            Grid.Column="0"
            CommandBinding="{Binding ClickCommand}"
            DisplayMemberBinding="{Binding Title}"
            ItemsSource="{Binding Breadcrumbs}"
            Margin="0,0,0,8">
            <u:Breadcrumb.Styles>
                <Style Selector="u|BreadcrumbItem" x:DataType="local:BreadcrumbItemModel">
                    <Setter Property="IsReadOnly" Value="{Binding IsReadOnly}" />
                </Style>
            </u:Breadcrumb.Styles>
        </u:Breadcrumb>
        <ContentControl
            Content="{Binding ActiveContent}"
            Grid.Column="0"
            Grid.Row="1" />
    </Grid>
</UserControl>
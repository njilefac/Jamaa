<UserControl
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d"
    x:Class="Jamaa.Desktop.Members.Components.MemberActionsPane"
    x:DataType="components:MemberListViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:components="clr-namespace:Jamaa.Desktop.Members.Components"
    xmlns:converters="clr-namespace:Jamaa.Desktop.Services.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:shared="clr-namespace:Jamaa.Desktop.Shared"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <converters:BoolToObjectConverter
            FalseValue="True"
            TrueValue="False"
            x:Key="InvertBoolToEnabledConverter" />
    </UserControl.Resources>
    <Grid ColumnDefinitions="Auto, *">
        <StackPanel
            Grid.Column="0"
            Grid.ColumnSpan="2"
            HorizontalAlignment="Center"
            Margin="4"
            Orientation="Horizontal"
            Spacing="8"
            VerticalAlignment="Stretch">
            <Button
                Content="Add Member"
                Height="40"
                IsEnabled="{Binding IsOperationInFlight, Converter={StaticResource InvertBoolToEnabledConverter}}"
                Width="150">
                <Interaction.Behaviors>
                    <EventTriggerBehavior EventName="Click">
                        <InvokeCommandAction Command="{Binding RegisterMemberCommand}" />
                    </EventTriggerBehavior>
                </Interaction.Behaviors>
            </Button>
        </StackPanel>

        <shared:OperationStatusBanner
            Grid.Column="1"
            HorizontalAlignment="Right"
            IsActive="{Binding IsOperationInFlight}"
            Margin="0,0,16,0"
            Message="Waiting for member confirmation..."
            VerticalAlignment="Center"
            Width="220" />
    </Grid>
</UserControl>
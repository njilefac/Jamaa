<Application
    Name="Libota Desktop"
    RequestedThemeVariant="Default"
    x:Class="Jamaa.Desktop.App"
    xmlns="https://github.com/avaloniaui"
    xmlns:accounting="clr-namespace:Jamaa.Desktop.Accounting"
    xmlns:components="clr-namespace:Jamaa.Desktop.Members.Components"
    xmlns:converters="clr-namespace:Jamaa.Desktop.Services.Converters"
    xmlns:dashboard="clr-namespace:Jamaa.Desktop.Dashboard"
    xmlns:events-View-Models="clr-namespace:Jamaa.Desktop.Events"
    xmlns:husk="https://github.com/d3ara1n/Huskui.Avalonia"
    xmlns:pages="clr-namespace:Jamaa.Desktop.Members.Pages"
    xmlns:security="clr-namespace:Jamaa.Desktop.Security"
    xmlns:semi="clr-namespace:Semi.Avalonia;assembly=Semi.Avalonia"
    xmlns:settings="clr-namespace:Jamaa.Desktop.Settings"
    xmlns:setup="clr-namespace:Jamaa.Desktop.Setup"
    xmlns:shared="clr-namespace:Jamaa.Desktop.Shared"
    xmlns:sty="using:FluentAvalonia.Styling"
    xmlns:u-semi="clr-namespace:Ursa.Themes.Semi;assembly=Ursa.Themes.Semi"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="/Themes/JamaaTheme.axaml" />
            </ResourceDictionary.MergedDictionaries>
            <converters:MemberProfileCommandArgsConverter x:Key="MemberProfileCommandArgsConverter" />
            <converters:MultiValueConverter x:Key="MultiValueConverter" />
            <converters:ByteArrayToBitmapConverter x:Key="ByteArrayToBitmapConverter" />
            <converters:EnumToBoolConverter x:Key="EnumToBoolConverter" />
            <converters:IncrementConverter x:Key="IncrementConverter" />
            <converters:HalfWidthConverter x:Key="HalfWidthConverter" />
        </ResourceDictionary>
    </Application.Resources>

    <Application.Styles>
        <husk:HuskuiTheme Corner="Normal" />
        <sty:FluentAvaloniaTheme />
        <semi:SemiTheme />
        <u-semi:SemiTheme />
        <StyleInclude Source="avares://Semi.Avalonia.DataGrid/Index.axaml" />
        <StyleInclude Source="avares://Semi.Avalonia.TreeDataGrid/Index.axaml" />
        <StyleInclude Source="avares://Jamaa/Styles/JamaaStyles.axaml" />
        <StyleInclude Source="avares://FluentAvalonia.BreadcrumbBar/Styling/Styles.axaml" />
    </Application.Styles>

    <Application.DataTemplates>
        <DataTemplate DataType="{x:Type shared:ShellViewModel}">
            <shared:Shell />
        </DataTemplate>
        <DataTemplate DataType="{x:Type dashboard:DashboardViewModel}">
            <dashboard:Dashboard />
        </DataTemplate>
        <DataTemplate DataType="{x:Type shared:MainMenuViewModel}">
            <shared:MainMenu />
        </DataTemplate>
        <DataTemplate DataType="{x:Type shared:MainWindowViewModel}">
            <shared:MainWindow />
        </DataTemplate>
        <DataTemplate DataType="{x:Type setup:CreateOrganisationViewModel}">
            <setup:CreateOrganisationScreen />
        </DataTemplate>
        <DataTemplate DataType="{x:Type setup:CreateSuperUserViewModel}">
            <setup:CreateSuperUserScreen />
        </DataTemplate>
        <DataTemplate DataType="{x:Type security:LoginScreenViewModel}">
            <security:LoginScreen />
        </DataTemplate>
        <DataTemplate DataType="{x:Type pages:MembersOverviewViewModel}">
            <pages:MembersOverviewPage />
        </DataTemplate>
        <DataTemplate DataType="{x:Type pages:MemberProfileViewModel}">
            <pages:MemberProfilePage />
        </DataTemplate>
        <DataTemplate DataType="{x:Type accounting:AccountingDashboardViewModel}">
            <accounting:AccountingDashboard />
        </DataTemplate>
        <DataTemplate DataType="{x:Type accounting:ChartOfAccountsViewModel}">
            <accounting:ChartOfAccountsPage />
        </DataTemplate>
        <DataTemplate DataType="{x:Type accounting:JournalEntriesViewModel}">
            <accounting:JournalEntriesPage />
        </DataTemplate>
        <DataTemplate DataType="{x:Type accounting:BankReconciliationViewModel}">
            <accounting:BankReconciliationPage />
        </DataTemplate>
        <DataTemplate DataType="{x:Type accounting:AccountingReportsViewModel}">
            <accounting:AccountingReportsPage />
        </DataTemplate>
        <DataTemplate DataType="{x:Type accounting:AccountingConfigurationViewModel}">
            <accounting:AccountingConfigurationPage />
        </DataTemplate>
        <DataTemplate DataType="{x:Type accounting:AccountingCurrencyAndDateFormatsViewModel}">
            <accounting:AccountingCurrencyAndDateFormatsPage />
        </DataTemplate>
        <DataTemplate DataType="{x:Type accounting:FiscalCalendarAndPeriodsViewModel}">
            <accounting:FiscalCalendarAndPeriodsPage />
        </DataTemplate>
        <DataTemplate DataType="{x:Type accounting:TaxGroupsAndAuthoritiesViewModel}">
            <accounting:TaxGroupsAndAuthoritiesPage />
        </DataTemplate>
        <DataTemplate DataType="{x:Type accounting:AutomationRulesViewModel}">
            <accounting:AutomationRulesPage />
        </DataTemplate>
        <DataTemplate DataType="{x:Type accounting:UserRolesAndApprovalsViewModel}">
            <accounting:UserRolesAndApprovalsPage />
        </DataTemplate>
        <DataTemplate DataType="{x:Type accounting:OpeningBalancesAndMigrationViewModel}">
            <accounting:OpeningBalancesAndMigrationPage />
        </DataTemplate>
        <DataTemplate DataType="{x:Type accounting:AccountLedgerViewModel}">
            <accounting:AccountLedgerPage />
        </DataTemplate>
        <DataTemplate DataType="{x:Type components:MemberListViewModel}">
            <components:MembersList />
        </DataTemplate>
        <DataTemplate DataType="{x:Type components:MembersSummary}">
            <components:MembersSummaryPane />
        </DataTemplate>
        <DataTemplate DataType="{x:Type events-View-Models:EventsOverviewPageViewModel}">
            <events-View-Models:EventOverviewPage />
        </DataTemplate>
        <DataTemplate DataType="{x:Type settings:SettingsViewModel}">
            <settings:SettingsPage />
        </DataTemplate>
    </Application.DataTemplates>
</Application>
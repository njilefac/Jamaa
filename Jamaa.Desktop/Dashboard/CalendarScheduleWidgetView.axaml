<UserControl
    d:DesignHeight="300"
    d:DesignWidth="300"
    mc:Ignorable="d"
    x:Class="Jamaa.Desktop.Dashboard.CalendarScheduleWidgetView"
    x:DataType="dashboard:CalendarScheduleWidgetViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dashboard="clr-namespace:Jamaa.Desktop.Dashboard"
    xmlns:fluent="clr-namespace:FluentAvalonia.UI.Controls;assembly=FluentAvalonia"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Classes="dashboard widget panel" Margin="16">
        <fluent:IconSourceElement
            Foreground="{DynamicResource SystemAccentColor}"
            HorizontalAlignment="Stretch"
            IconSource="{StaticResource Icons.Calendar}"
            Opacity="0.85"
            VerticalAlignment="Stretch" />
    </Border>
</UserControl>
<UserControl
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d"
    x:Class="Jamaa.Desktop.Dashboard.BookkeepingWidgetView"
    x:DataType="dashboard:BookkeepingWidgetViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dashboard="clr-namespace:Jamaa.Desktop.Dashboard"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid
        Margin="16"
        RowDefinitions="Auto,*,Auto"
        RowSpacing="12">
        <StackPanel>
            <TextBlock
                Classes="dashboard widget text secondary"
                FontSize="12"
                Text="Financial Summary" />
            <TextBlock
                Classes="dashboard widget text primary dashboard widget metric value"
                FontSize="32"
                FontWeight="Bold"
                Text="$0.00" />
        </StackPanel>

        <Grid
            ColumnDefinitions="*,*"
            ColumnSpacing="12"
            Grid.Row="1">
            <Border Classes="dashboard widget panel">
                <StackPanel>
                    <TextBlock
                        Classes="dashboard widget text secondary"
                        FontSize="12"
                        Text="Revenue" />
                    <TextBlock
                        Classes="dashboard widget text primary dashboard widget metric success"
                        FontSize="20"
                        FontWeight="Bold"
                        Text="$0.00" />
                </StackPanel>
            </Border>

            <Border Classes="dashboard widget panel" Grid.Column="1">
                <StackPanel>
                    <TextBlock
                        Classes="dashboard widget text secondary"
                        FontSize="12"
                        Text="Expenses" />
                    <TextBlock
                        Classes="dashboard widget text primary"
                        FontSize="20"
                        FontWeight="Bold"
                        Text="$0.00" />
                </StackPanel>
            </Border>
        </Grid>

        <TextBlock
            Classes="dashboard widget text secondary"
            Grid.Row="2"
            Text="Use the accounting workspace to review journal entries, reports, and reconciliations."
            TextWrapping="Wrap" />
    </Grid>
</UserControl>

<UserControl
    d:DesignHeight="300"
    d:DesignWidth="300"
    mc:Ignorable="d"
    x:Class="Jamaa.Desktop.Dashboard.AlertsAndNotificationsWidgetView"
    x:DataType="dashboard:AlertsAndNotificationsWidgetViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dashboard="clr-namespace:Jamaa.Desktop.Dashboard"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="16">
        <StackPanel Spacing="12">
            <Border
                Background="#FEE2E2"
                CornerRadius="4"
                Padding="8">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Path
                        Data="M12,2L1,21H23L12,2M12,6L19.53,19H4.47L12,6M11,10V14H13V10H11M11,16V18H13V16H11Z"
                        Fill="#EF4444"
                        Height="16"
                        Stretch="Uniform"
                        Width="16" />
                    <TextBlock
                        FontSize="12"
                        Foreground="#991B1B"
                        Text="3 members overdue on dues"
                        VerticalAlignment="Center" />
                </StackPanel>
            </Border>
            <Border
                Background="#FEF3C7"
                CornerRadius="4"
                Padding="8">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Path
                        Data="M11,9H13V11H11V9M11,13H13V17H11V13M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2M12,20A8,8 0 0,1 4,12A8,8 0 0,1 12,4A8,8 0 0,1 20,12A8,8 0 0,1 12,20Z"
                        Fill="#F59E0B"
                        Height="16"
                        Stretch="Uniform"
                        Width="16" />
                    <TextBlock
                        FontSize="12"
                        Foreground="#92400E"
                        Text="New registration request"
                        VerticalAlignment="Center" />
                </StackPanel>
            </Border>
            <Border
                Background="#DBEAFE"
                CornerRadius="4"
                Padding="8">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Path
                        Data="M11,9H13V11H11V9M11,13H13V17H11V13M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 22,12A10,10 0 0,0 12,2M12,20A8,8 0 0,1 4,12A8,8 0 0,1 12,4A8,8 0 0,1 20,12A8,8 0 0,1 12,20Z"
                        Fill="#3B82F6"
                        Height="16"
                        Stretch="Uniform"
                        Width="16" />
                    <TextBlock
                        FontSize="12"
                        Foreground="#1E40AF"
                        Text="Meeting starting in 30 min"
                        VerticalAlignment="Center" />
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>

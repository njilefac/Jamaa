<UserControl
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d"
    x:Class="Jamaa.Desktop.Dashboard.Dashboard"
    x:DataType="dashboard:DashboardViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dashboard="clr-namespace:Jamaa.Desktop.Dashboard"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Classes="dashboard page" RowDefinitions="Auto,*">
        <Border Classes="dashboard page header" Grid.Row="0">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="20">
                <StackPanel>
                    <TextBlock Classes="dashboard page title" Text="Association Dashboard" />
                    <TextBlock
                        Classes="dashboard page subtitle"
                        Text="Keep track of membership, finances, alerts, and activity from a single workspace tailored to your organisation."
                        Width="{Binding $parent[UserControl].Bounds.Width, Converter={StaticResource HalfWidthConverter}}" />
                </StackPanel>

                <StackPanel
                    Grid.Column="1"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center">
                    <Button
                        Classes="dashboard header action"
                        Command="{Binding ResetLayoutCommand}"
                        Content="Reset Layout" />
                </StackPanel>
            </Grid>
        </Border>

        <ItemsControl
            Classes="dashboard grid"
            Grid.Row="1"
            ItemsSource="{Binding ActiveWidgets}">

            <ItemsControl.Styles>
                <Style Selector="ItemsControl &gt; ContentPresenter">
                    <Setter Property="Grid.Row" Value="{Binding Row}" />
                    <Setter Property="Grid.Column" Value="{Binding Column}" />
                </Style>
            </ItemsControl.Styles>

            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <Grid ColumnDefinitions="*,3*,*" RowDefinitions="*,*" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>

            <ItemsControl.ItemTemplate>
                <DataTemplate DataType="{x:Type dashboard:WidgetViewModelBase}">
                    <dashboard:WidgetView />
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>
</UserControl>
<UserControl
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d"
    x:Class="Jamaa.Desktop.Dashboard.Dashboard"
    x:DataType="dashboard:DashboardViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dashboard="clr-namespace:Jamaa.Desktop.Dashboard"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid RowDefinitions="Auto, *">
        <StackPanel
            Grid.Row="0"
            HorizontalAlignment="Left"
            Margin="8"
            Orientation="Horizontal"
            Width="{Binding $parent[UserControl].Bounds.Width, Converter={StaticResource HalfWidthConverter}}">
            <Button Command="{Binding ResetLayoutCommand}" Content="Reset Layout" />
        </StackPanel>

        <ItemsControl
            Classes="dashboard grid"
            Grid.Row="1"
            ItemsSource="{Binding ActiveWidgets}">

            <ItemsControl.Styles>
                <Style Selector="ItemsControl &gt; ContentPresenter">
                    <Setter Property="Grid.Row" Value="{Binding Row}" />
                    <Setter Property="Grid.Column" Value="{Binding Column}" />
                </Style>
            </ItemsControl.Styles>

            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <Grid ColumnDefinitions="*,2*,*" RowDefinitions="*,*" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>

            <ItemsControl.ItemTemplate>
                <DataTemplate DataType="{x:Type dashboard:WidgetViewModelBase}">
                    <dashboard:WidgetView />
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>
</UserControl>

<UserControl
    x:Class="Jamaa.Desktop.Setup.CreateSuperUserScreen"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    HorizontalAlignment="Center"
    VerticalAlignment="Center"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d"
    >

    <StackPanel>
        <TextBlock
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Classes="page title"
            Text="Create Super User"
            />
        <Grid ColumnDefinitions="Auto, Auto" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto">
            <TextBlock
                Grid.Row="0"
                Grid.Column="0"
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                Classes="form label"
                Text="User Name:"
                />
            <TextBox
                x:Name="UserNameField"
                Grid.Row="0"
                Grid.Column="1"
                Classes="form field"
                Text="{Binding UserName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                />
            <TextBlock
                Grid.Row="1"
                Grid.Column="0"
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                Classes="form label"
                Text="Email:"
                />
            <TextBox
                Grid.Row="1"
                Grid.Column="1"
                Classes="form field"
                Text="{Binding Email}"
                />
            <TextBlock
                Grid.Row="2"
                Grid.Column="0"
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                Classes="form label"
                Text="Password:"
                />
            <TextBox
                Grid.Row="2"
                Grid.Column="1"
                Classes="form field secret"
                Text="{Binding Password}"
                />
            <TextBlock
                Grid.Row="3"
                Grid.Column="0"
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                Classes="form label"
                Text="First Name:"
                />
            <TextBox
                Grid.Row="3"
                Grid.Column="1"
                Classes="form field"
                Text="{Binding FirstName}"
                />
            <TextBlock
                Grid.Row="4"
                Grid.Column="0"
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                Classes="form label"
                Text="Last Name:"
                />
            <TextBox
                Grid.Row="4"
                Grid.Column="1"
                Classes="form field"
                Text="{Binding LastName}"
                />
            <Button
                Grid.Row="5"
                Grid.Column="1"
                HorizontalAlignment="Right"
                Command="{Binding CreateSuperUserCommand}"
                Content="Create Account"
                IsDefault="True"
                />
        </Grid>
    </StackPanel>
</UserControl>

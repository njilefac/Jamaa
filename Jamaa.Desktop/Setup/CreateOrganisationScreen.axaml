<UserControl
    HorizontalAlignment="Center"
    VerticalAlignment="Center"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d"
    x:Class="Jamaa.Desktop.Setup.CreateOrganisationScreen"
    xmlns="https://github.com/avaloniaui"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <StackPanel>
        <TextBlock
            Classes="page title"
            HorizontalAlignment="Center"
            Text="Create Organisation"
            VerticalAlignment="Center" />
        <Grid ColumnDefinitions="Auto, Auto" RowDefinitions="Auto,Auto,Auto">
            <TextBlock
                Classes="form label"
                Grid.Column="0"
                Grid.Row="0"
                HorizontalAlignment="Right"
                Text="Organisation Name:"
                VerticalAlignment="Center" />
            <TextBox
                Classes="form field"
                Grid.Column="1"
                Grid.Row="0"
                Text="{Binding Mode=TwoWay, Path=Name, UpdateSourceTrigger=PropertyChanged}"
                x:Name="OrganisationNameField" />
            <TextBlock
                Classes="form label"
                Grid.Column="0"
                Grid.Row="1"
                HorizontalAlignment="Right"
                Text="Description:"
                VerticalAlignment="Center" />
            <TextBox
                Classes="form field"
                Grid.Column="1"
                Grid.Row="1"
                Text="{Binding Description}" />
            <Button
                Command="{Binding CreateOrganisationCommand}"
                Content="Create"
                Grid.Column="1"
                Grid.Row="2"
                HorizontalAlignment="Right"
                IsDefault="True" />
        </Grid>
    </StackPanel>
</UserControl>
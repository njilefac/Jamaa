<husk:AppWindow
    Background="Transparent"
    Icon="avares://Jamaa/Assets/Icons/jamaa.png"
    ShowActivated="True"
    Title="{Binding ApplicationTitle}"
    TransparencyLevelHint="Blur, Mica"
    WindowStartupLocation="CenterScreen"
    WindowState="Maximized"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d"
    x:Class="Jamaa.Desktop.Shared.Shell"
    x:DataType="shared:ShellViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:husk="https://github.com/d3ara1n/Huskui.Avalonia"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:shared="clr-namespace:Jamaa.Desktop.Shared"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid ColumnDefinitions="*" RowDefinitions="Auto,*,35">
        <shared:MainMenu Content="{Binding MainMenu}" Grid.Row="0" />
        <Panel Grid.Row="1">
            <ContentControl
                Content="{Binding ActiveContent}"
                HorizontalContentAlignment="Stretch"
                VerticalContentAlignment="Stretch" />
        </Panel>
        <Panel Grid.Row="2" />
    </Grid>
</husk:AppWindow>
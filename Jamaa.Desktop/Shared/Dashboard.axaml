<UserControl
    x:Class="Jamaa.Desktop.Shared.Dashboard"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:FluentAvalonia.UI.Controls;assembly=FluentAvalonia"
    xmlns:converters="clr-namespace:Jamaa.Desktop.Services.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="clr-namespace:Jamaa.Desktop.Services.Navigation.Models"
    xmlns:services="clr-namespace:Jamaa.Desktop.Services"
    xmlns:shared="clr-namespace:Jamaa.Desktop.Shared"
    HorizontalAlignment="Stretch"
    VerticalAlignment="Stretch"
    HorizontalContentAlignment="Stretch"
    VerticalContentAlignment="Stretch"
    d:DesignHeight="450"
    d:DesignWidth="800"
    x:DataType="shared:DashboardViewModel"
    mc:Ignorable="d"
    >

    <UserControl.Resources>
        <converters:JamaaIconSourceConverter x:Key="IconSourceConverter" />
        <Thickness x:Key="NavigationViewHeaderMargin">0</Thickness>
        <Thickness x:Key="NavigationViewHeaderPadding">0</Thickness>
        <Thickness x:Key="NavigationViewHeaderContentControlMargin">0</Thickness>
    </UserControl.Resources>

    <controls:NavigationView
        Margin="0"
        Padding="0"
        VerticalAlignment="Stretch"
        Header="{Binding}"
        MenuItemsSource="{Binding MenuItems}"
        PaneDisplayMode="Auto"
        SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
        >
        <controls:NavigationView.Content>
            <Border Background="{DynamicResource LayerFillColorDefaultBrush}">
                <ContentControl Content="{Binding ActiveModule}" />
            </Border>
        </controls:NavigationView.Content>

        <controls:NavigationView.MenuItemTemplate>
            <DataTemplate x:DataType="models:NavigationItemModel">
                <controls:NavigationViewItem
                    Content="{Binding Title}"
                    IconSource="{Binding Icon, Converter={StaticResource IconSourceConverter}}"
                    Tag="{Binding TargetRoute}"
                    />
            </DataTemplate>
        </controls:NavigationView.MenuItemTemplate>
        <controls:NavigationView.HeaderTemplate>
            <DataTemplate>
                <shared:DashboardHeader
                    Title="{Binding ActiveModule.Title}"
                    Classes="module header"
                    DataContext="{Binding ActiveModule}"
                    />
            </DataTemplate>
        </controls:NavigationView.HeaderTemplate>
    </controls:NavigationView>
</UserControl>
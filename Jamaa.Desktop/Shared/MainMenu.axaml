<UserControl
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d"
    x:Class="Jamaa.Desktop.Shared.MainMenu"
    x:DataType="shared:MainMenuViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:shared="clr-namespace:Jamaa.Desktop.Shared"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Menu DockPanel.Dock="Top">
        <MenuItem Header="File">
            <MenuItem Command="{Binding LogoutCommand}" Header="Logout" />
            <Separator />
            <MenuItem Command="{Binding ExitApplicationCommand}" Header="Exit" />
        </MenuItem>
        <MenuItem Header="Edit">
            <MenuItem Header="Import">
                <MenuItem Header="Members" IsSubMenuOpen="True" />
                <MenuItem Header="Financial Transactions" IsSubMenuOpen="True" />
            </MenuItem>
        </MenuItem>
    </Menu>

</UserControl>
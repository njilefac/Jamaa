<UserControl
    HorizontalAlignment="Stretch"
    HorizontalContentAlignment="Stretch"
    VerticalAlignment="Stretch"
    VerticalContentAlignment="Stretch"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d"
    x:Class="Jamaa.Desktop.Shared.MainWindow"
    x:DataType="shared:MainWindowViewModel"
    x:CompileBindings="False"
    xmlns="https://github.com/avaloniaui"
    xmlns:controls="clr-namespace:FluentAvalonia.UI.Controls;assembly=FluentAvalonia"
    xmlns:converters="clr-namespace:Jamaa.Desktop.Services.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="clr-namespace:Jamaa.Desktop.Services.Navigation.Models"
    xmlns:shared="clr-namespace:Jamaa.Desktop.Shared"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <converters:JamaaIconSourceConverter x:Key="IconSourceConverter" />
    </UserControl.Resources>

    <controls:FADialogHost>
        <controls:FANavigationView
            Header="{Binding}"
            HorizontalContentAlignment="Stretch"
            IsSettingsVisible="True"
            Margin="0"
            MenuItemsSource="{Binding MenuItems}"
            Padding="0"
            PaneDisplayMode="Auto"
            SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
            SelectionChanged="OnNavigationSelectionChanged"
            VerticalAlignment="Stretch"
            VerticalContentAlignment="Stretch">
            <controls:FANavigationView.Content>
                <Border
                    Background="{DynamicResource AppLayerBackground}"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch">
                    <ContentControl
                        Content="{Binding ActiveModule}"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        VerticalContentAlignment="Stretch" />
                </Border>
            </controls:FANavigationView.Content>

            <controls:FANavigationView.MenuItemTemplate>
                <DataTemplate x:DataType="models:NavigationItemModel">
                    <controls:FANavigationViewItem
                        Content="{Binding Title}"
                        IconSource="{Binding Icon, Converter={StaticResource IconSourceConverter}}"
                        MenuItemsSource="{Binding SubItems}"
                        SelectsOnInvoked="{Binding SubItems, Converter={x:Static ObjectConverters.IsNull}}"
                        Tag="{Binding TargetRoute}" />
                </DataTemplate>
            </controls:FANavigationView.MenuItemTemplate>
            <controls:FANavigationView.HeaderTemplate>
                <DataTemplate>
                    <shared:ModulePageHeader
                        Classes="module header"
                        DataContext="{Binding ActiveModule}"
                        Title="{Binding ActiveModule.Title}" />
                </DataTemplate>
            </controls:FANavigationView.HeaderTemplate>
        </controls:FANavigationView>
    </controls:FADialogHost>
</UserControl>
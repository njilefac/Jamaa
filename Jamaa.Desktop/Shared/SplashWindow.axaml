<husk:AppWindow
    x:Class="Jamaa.Desktop.Shared.SplashWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:husk="https://github.com/d3ara1n/Huskui.Avalonia"
    xmlns:shared="clr-namespace:Jamaa.Desktop.Shared"
    Title="Libota"
    Width="600"
    Height="400"
    x:DataType="shared:SplashViewModel"
    SystemDecorations="None"
    WindowStartupLocation="CenterScreen"
    Icon="avares://Jamaa/Assets/Icons/jamaa.png"
    >
    <Grid RowDefinitions="*,Auto">
        <Image
            Grid.Row="0"
            Source="avares://Jamaa/Assets/splash.png"
            Stretch="UniformToFill"
            />
        <StackPanel
            Grid.Row="1"
            Margin="0,10,0,10"
            Background="Transparent"
            >
            <TextBlock
                Margin="0,0,0,5"
                HorizontalAlignment="Center"
                FontSize="14"
                Foreground="{DynamicResource TextControlForeground}"
                Text="{Binding Status}"
                />
            <ProgressBar
                Height="4"
                HorizontalAlignment="Stretch"
                IsIndeterminate="False"
                Minimum="0"
                Maximum="100"
                Value="{Binding Progress}"
                Foreground="{DynamicResource ProgressBarForeground}"
                Background="Transparent"
                BorderThickness="0"
                />
        </StackPanel>
    </Grid>
</husk:AppWindow>

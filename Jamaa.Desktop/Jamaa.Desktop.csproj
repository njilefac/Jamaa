    <ItemGroup>
        <InternalsVisibleTo Include="UnitTests" />
    </ItemGroup>

    <ItemGroup>
        <AvaloniaResource Include="Assets\Resources\Messages.resx">
            <Generator>ResXFileCodeGenerator</Generator>
            <LastGenOutput>Messages.Designer.cs</LastGenOutput>
            <CustomToolNamespace>Jamaa.Desktop.Assets.Resources</CustomToolNamespace>
        </AvaloniaResource>
    </ItemGroup>

    <ItemGroup>
        <ProjectReference Include="..\Jamaa.Elsa.Studio\Jamaa.Elsa.Studio.csproj" />
        <ProjectReference Include="..\Jamaa.Application\Jamaa.Application.csproj" />
        <ProjectReference Include="..\Jamaa.Data\Jamaa.Data.csproj" />
        <ProjectReference Include="..\Jamaa.Domain\Jamaa.Domain.csproj" />
    </ItemGroup>

    <ItemGroup>
        <EmbeddedResource Update="Assets\Resources\Messages.en.resx">
            <DependentUpon>Messages.resx</DependentUpon>
        </EmbeddedResource>
        <EmbeddedResource Update="Assets\Resources\Messages.fr-fr.resx">
            <DependentUpon>Messages.resx</DependentUpon>
        </EmbeddedResource>
    </ItemGroup>
</Project>

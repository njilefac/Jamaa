<Project Sdk="Microsoft.NET.Sdk.Web">
    <PropertyGroup>
        <OutputType>WinExe</OutputType>
        <TargetFramework>net10.0</TargetFramework>
        <Nullable>enable</Nullable>
        <Company>Nubia Systems</Company>
        <Product>Jamaa Desktop</Product>
        <PackageId>Jamaa</PackageId>
        <Authors>Wilfred Azamo</Authors>
        <Version>1.0.0</Version>
        <NeutralLanguage>en</NeutralLanguage>
        <AssemblyName>Jamaa</AssemblyName>
        <ApplicationIcon>Assets/Icons/jamaa.ico</ApplicationIcon>
        <CFBundleIconFile>Assets/Icons/jamaa.icns</CFBundleIconFile>
        <CFBundleName>Jamaa</CFBundleName>
        <CFBundleDisplayName>Jamaa</CFBundleDisplayName>
        <CFBundleIdentifier>com.nubiasystems.jamaa</CFBundleIdentifier>
        <CFBundleVersion>$(Version)</CFBundleVersion>
        <CFBundleShortVersionString>$(Version)</CFBundleShortVersionString>
        <CFBundleExecutable>Jamaa</CFBundleExecutable>
        <SelfContained>true</SelfContained>
        <GenerateResourceDesignerFiles>true</GenerateResourceDesignerFiles>
        <DefaultItemExcludes>$(DefaultItemExcludes);Logs\**</DefaultItemExcludes>
    </PropertyGroup>
    <ItemGroup>
        <Content Include="Assets\Icons\jamaa.icns" CopyToPublishDirectory="Always" />
    </ItemGroup>

    <Target Name="CopyIconToBundle" AfterTargets="BundleApp">
        <Copy SourceFiles="$(PublishDir)Assets/Icons/jamaa.icns" DestinationFiles="$(PublishDir)$(CFBundleName).app/Contents/Resources/jamaa.icns" />
    </Target>
    <ItemGroup>
        <AvaloniaResource Include="Assets\Icons\**" />
        <AvaloniaResource Include="Assets\Styles\**" />
        <AvaloniaResource Include="Assets\splash.png" />
    </ItemGroup>
    <ItemGroup>

<UserControl
    HorizontalAlignment="Stretch"
    HorizontalContentAlignment="Stretch"
    VerticalAlignment="Stretch"
    VerticalContentAlignment="Stretch"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d"
    x:Class="Jamaa.Desktop.Accounting.AutomationRulesPage"
    x:DataType="accounting:AutomationRulesViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:accounting="clr-namespace:Jamaa.Desktop.Accounting"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:sharedControls="clr-namespace:Jamaa.Desktop.Shared.Controls"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid
        HorizontalAlignment="Stretch"
        Margin="20"
        VerticalAlignment="Stretch">
        <Border
            Background="{DynamicResource AppCardBackground}"
            BorderBrush="{DynamicResource AppBorderColor}"
            BorderThickness="1"
            CornerRadius="{DynamicResource ControlCornerRadius}"
            HorizontalAlignment="Stretch"
            Padding="10"
            VerticalAlignment="Stretch">
            <sharedControls:EmbeddedBrowser
                HorizontalAlignment="Stretch"
                TargetUrl="{Binding ElsaStudioUrl}"
                VerticalAlignment="Stretch" />
        </Border>
    </Grid>
</UserControl>
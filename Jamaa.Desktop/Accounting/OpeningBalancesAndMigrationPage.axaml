<UserControl
    d:DesignHeight="600"
    d:DesignWidth="900"
    mc:Ignorable="d"
    x:Class="Jamaa.Desktop.Accounting.OpeningBalancesAndMigrationPage"
    x:DataType="accounting:OpeningBalancesAndMigrationViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:accounting="clr-namespace:Jamaa.Desktop.Accounting"
    xmlns:behaviors="clr-namespace:Jamaa.Desktop.Shared.Behaviors"
    xmlns:converters="clr-namespace:Jamaa.Desktop.Services.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <converters:DecimalToFormattedStringConverter x:Key="DecimalToFormattedStringConverter" />
    </UserControl.Resources>

    <Grid RowDefinitions="Auto,Auto,*">
        <StackPanel Margin="20,16,20,0" Spacing="8">
            <TextBlock Classes="h1" Text="Opening Balances &amp; Migration" />
            <TextBlock Foreground="{DynamicResource AppTextSecondary}" Text="Enter opening balances only for leaf accounts (lowest level in the hierarchy). Parent accounts automatically aggregate balances from their children to prevent double-counting." />
        </StackPanel>

        <Border
            Background="{DynamicResource AppDividerColor}"
            Grid.Row="1"
            Height="1"
            Margin="20,12,20,12" />

        <Grid
            Grid.Row="2"
            Margin="20,0,20,20"
            RowDefinitions="*">
            <!--  Account list with hierarchical indentation (flat ItemsRepeater)  -->
            <ScrollViewer>
                <ItemsRepeater ItemsSource="{Binding LeafAccounts}">
                    <ItemsRepeater.Layout>
                        <StackLayout Spacing="0" />
                    </ItemsRepeater.Layout>
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate x:DataType="accounting:OpeningBalanceItemViewModel">
                            <Border
                                BorderBrush="{DynamicResource AppBorderColor}"
                                BorderThickness="0,0,0,1"
                                Padding="8,12">
                                <Grid ColumnDefinitions="400,150,Auto,*">
                                    <!--  Account Info  -->
                                    <StackPanel Grid.Column="0" Spacing="4">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock FontWeight="Bold" Text="{Binding Code}" />
                                            <TextBlock FontSize="12" Text="{Binding Name}" />
                                        </StackPanel>
                                        <TextBlock
                                            FontSize="10"
                                            Foreground="{DynamicResource AppTextSecondary}"
                                            Text="{Binding TypeDisplay}" />
                                    </StackPanel>

                                    <!--  Balance: Leaf Input or Parent Readonly  -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <!--  Leaf: editable balance  -->
                                        <TextBox
                                            HorizontalAlignment="Stretch"
                                            IsVisible="{Binding IsLeafAccount}"
                                            Watermark="0.00">
                                            <Interaction.Behaviors>
                                                <behaviors:RefreshOnLostFocusBehavior />
                                            </Interaction.Behaviors>
                                            <TextBox.Text>
                                                <Binding
                                                    Converter="{StaticResource DecimalToFormattedStringConverter}"
                                                    Mode="TwoWay"
                                                    Path="OpeningBalance"
                                                    UpdateSourceTrigger="PropertyChanged" />
                                            </TextBox.Text>
                                            <TextBox.InnerLeftContent>
                                                <TextBlock
                                                    Margin="8,0,0,0"
                                                    Text="{Binding CurrencySymbol}"
                                                    VerticalAlignment="Center" />
                                            </TextBox.InnerLeftContent>
                                        </TextBox>
                                    </StackPanel>

                                    <!--  Actions  -->
                                    <StackPanel
                                        Grid.Column="2"
                                        Margin="12,0,0,0"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Center">
                                        <Button
                                            Command="{Binding SaveOpeningBalanceCommand}"
                                            IsEnabled="{Binding !IsSaving}"
                                            IsVisible="{Binding IsLeafAccount}"
                                            Padding="12,6"
                                            Theme="{DynamicResource SolidButton}">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <PathIcon Data="{StaticResource save_regular}" Height="14" />
                                                <TextBlock Text="Save" />
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
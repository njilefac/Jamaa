<UserControl
    d:DesignHeight="600"
    d:DesignWidth="900"
    mc:Ignorable="d"
    x:Class="Jamaa.Desktop.Accounting.OpeningBalancesAndMigrationPage"
    x:DataType="accounting:OpeningBalancesAndMigrationViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:accounting="clr-namespace:Jamaa.Desktop.Accounting"
    xmlns:behaviors="clr-namespace:Jamaa.Desktop.Shared.Behaviors"
    xmlns:converters="clr-namespace:Jamaa.Desktop.Services.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <converters:DecimalToFormattedStringConverter x:Key="DecimalToFormattedStringConverter" />

        <!--  Opening Balance cell: editable TextBox for leaf accounts, read-only label for parents  -->
        <DataTemplate x:DataType="accounting:OpeningBalanceItemViewModel" x:Key="BalanceCellTemplate">
            <Panel>
                <!--  Leaf account: editable (or read-only once saved)  -->
                <TextBox
                    HorizontalAlignment="Stretch"
                    IsReadOnly="{Binding IsLocked}"
                    IsVisible="{Binding IsLeafAccount}"
                    Watermark="0.00">
                    <Interaction.Behaviors>
                        <behaviors:RefreshOnLostFocusBehavior />
                    </Interaction.Behaviors>
                    <TextBox.Text>
                        <MultiBinding
                            Converter="{StaticResource DecimalToFormattedStringConverter}"
                            Mode="TwoWay">
                            <Binding Path="OpeningBalance" />
                            <Binding Path="DecimalPrecision" />
                            <Binding Path="ThousandSeparator" />
                        </MultiBinding>
                    </TextBox.Text>
                    <TextBox.InnerLeftContent>
                        <TextBlock
                            Margin="8,0,0,0"
                            Text="{Binding CurrencySymbol}"
                            VerticalAlignment="Center" />
                    </TextBox.InnerLeftContent>
                </TextBox>

                <!--  Parent account: aggregated balance, display-only  -->
                <TextBlock
                    FontWeight="SemiBold"
                    Foreground="{DynamicResource AppTextSecondary}"
                    HorizontalAlignment="Right"
                    IsVisible="{Binding !IsLeafAccount}"
                    VerticalAlignment="Center">
                    <TextBlock.Text>
                        <MultiBinding Converter="{StaticResource DecimalToFormattedStringConverter}">
                            <Binding Path="OpeningBalance" />
                            <Binding Path="DecimalPrecision" />
                            <Binding Path="ThousandSeparator" />
                        </MultiBinding>
                    </TextBlock.Text>
                </TextBlock>
            </Panel>
        </DataTemplate>

        <!--  Save action cell: visible only for editable leaf accounts  -->
        <DataTemplate x:DataType="accounting:OpeningBalanceItemViewModel" x:Key="SaveCellTemplate">
            <StackPanel HorizontalAlignment="Left" Orientation="Horizontal">
                <Button
                    Command="{Binding SaveOpeningBalanceCommand}"
                    IsEnabled="{Binding !IsSaving}"
                    IsVisible="{Binding CanEdit}"
                    Padding="12,6"
                    Theme="{DynamicResource SolidButton}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <PathIcon
                            Data="M17 3H5C3.9 3 3 3.9 3 5V19C3 20.1 3.9 21 5 21H19C20.1 21 21 20.1 21 19V7L17 3ZM12 19C10.34 19 9 17.66 9 16C9 14.34 10.34 13 12 13C13.66 13 15 14.34 15 16C15 17.66 13.66 19 12 19ZM6 5H15V9H6V5Z"
                            Height="14" />
                        <TextBlock Text="Save" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </DataTemplate>
    </UserControl.Resources>

    <Grid RowDefinitions="Auto,Auto,*">
        <StackPanel Margin="20,16,20,0" Spacing="8">
            <TextBlock Classes="h1" Text="Opening Balances &amp; Migration" />
            <TextBlock Foreground="{DynamicResource AppTextSecondary}" Text="Enter opening balances only for leaf accounts (lowest level in the hierarchy). Parent accounts automatically aggregate balances from their children to prevent double-counting." />
        </StackPanel>

        <Border
            Background="{DynamicResource AppDividerColor}"
            Grid.Row="1"
            Height="1"
            Margin="20,12,20,12" />

        <Border
            BorderBrush="{DynamicResource AppBorderColor}"
            BorderThickness="1"
            ClipToBounds="True"
            CornerRadius="8"
            Grid.Row="2"
            Margin="20,0,20,20">
            <TreeDataGrid x:Name="BalancesTreeDataGrid" />
        </Border>
    </Grid>
</UserControl>

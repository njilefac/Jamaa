<UserControl
    d:DesignHeight="600"
    d:DesignWidth="900"
    mc:Ignorable="d"
    x:Class="Jamaa.Desktop.Accounting.OpeningBalancesAndMigrationPage"
    x:DataType="accounting:OpeningBalancesAndMigrationViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:accounting="clr-namespace:Jamaa.Desktop.Accounting"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid RowDefinitions="Auto,Auto,*">
        <StackPanel Margin="20,16,20,0" Spacing="8">
            <TextBlock Classes="h1" Text="Opening Balances &amp; Migration" />
            <TextBlock Foreground="{DynamicResource AppTextSecondary}" Text="Enter opening balances only for leaf accounts (lowest level in the hierarchy). Parent accounts automatically aggregate balances from their children to prevent double-counting." />
        </StackPanel>

        <Border
            Background="{DynamicResource AppDividerColor}"
            Grid.Row="1"
            Height="1"
            Margin="20,12,20,12" />

        <Grid
            Grid.Row="2"
            Margin="20,0,20,20"
            RowDefinitions="*,Auto">
            <!--  Account list with hierarchical indentation (flat ItemsRepeater)  -->
            <ScrollViewer>
                <ItemsRepeater ItemsSource="{Binding AccountTree}">
                    <ItemsRepeater.Layout>
                        <StackLayout Spacing="0" />
                    </ItemsRepeater.Layout>
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate x:DataType="accounting:AccountItemViewModel">
                            <Border
                                BorderBrush="{DynamicResource AppBorderColor}"
                                BorderThickness="0,0,0,1"
                                Padding="8,12">
                                <Grid ColumnDefinitions="*,120,100">
                                    <!--  Account Info (indented by Depth)  -->
                                    <StackPanel
                                        Grid.Column="0"
                                        Margin="{Binding Depth, StringFormat='({0}*12) 0 0 0'}"
                                        Spacing="4">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock FontWeight="Bold" Text="{Binding Code}" />
                                            <TextBlock FontSize="12" Text="{Binding Name}" />
                                        </StackPanel>
                                        <TextBlock
                                            FontSize="10"
                                            Foreground="{DynamicResource AppTextSecondary}"
                                            Text="{Binding TypeDisplay}" />
                                    </StackPanel>

                                    <!--  Balance: Leaf Input or Parent Readonly  -->
                                    <Border
                                        BorderBrush="{DynamicResource AppBorderColor}"
                                        BorderThickness="1"
                                        Grid.Column="1"
                                        Padding="8">
                                        <StackPanel>
                                            <!--  Leaf: editable balance  -->
                                            <TextBox
                                                HorizontalAlignment="Stretch"
                                                IsVisible="{Binding IsLeafAccount}"
                                                Text="{Binding OpeningBalance, StringFormat=F2}"
                                                Watermark="0.00" />
                                            <!--  Parent: aggregated readonly  -->
                                            <TextBlock
                                                FontWeight="Bold"
                                                Foreground="{DynamicResource SystemAccentColor}"
                                                HorizontalAlignment="Center"
                                                IsVisible="{Binding IsLeafAccount, Converter={x:Static BoolConverters.Not}}"
                                                Text="{Binding AggregatedOpeningBalance, StringFormat=F2}"
                                                VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Border>

                                    <!--  Account Role Label  -->
                                    <TextBlock
                                        FontSize="10"
                                        Foreground="{DynamicResource AppTextSecondary}"
                                        Grid.Column="2"
                                        Text="{Binding IsLeafAccount, StringFormat='Leaf (Edit)|Parent (Agg)'}"
                                        VerticalAlignment="Center" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
            </ScrollViewer>

            <!--  Status banner  -->
            <StackPanel
                Grid.Row="1"
                Margin="0,12,0,0"
                Spacing="12">
                <Border Background="{DynamicResource AppBorderColor}" Height="1" />
                <TextBlock
                    FontSize="12"
                    Foreground="{DynamicResource AppTextSecondary}"
                    IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                    Text="{Binding StatusMessage}"
                    TextWrapping="Wrap" />
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
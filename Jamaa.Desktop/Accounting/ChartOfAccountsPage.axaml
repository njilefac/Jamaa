<UserControl
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d"
    x:Class="Jamaa.Desktop.Accounting.ChartOfAccountsPage"
    x:DataType="vm:ChartOfAccountsViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:converters="clr-namespace:Jamaa.Desktop.Services.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:Jamaa.Desktop.Accounting"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <converters:BoolToObjectConverter
            FalseValue="Transparent"
            TrueValue="{StaticResource SystemAccentColorLight3}"
            x:Key="EditModeBackgroundConverter" />
    </UserControl.Resources>

    <StackPanel Margin="20" Spacing="20">
        <TextBlock Classes="h1" Text="{Binding PageTitle}" />

        <Grid ColumnDefinitions="*, 300">
            <StackPanel
                Grid.Column="0"
                Margin="0,0,20,0"
                Spacing="10">
                <TextBlock Classes="h2" Text="Accounts" />
                <Border
                    BorderBrush="{DynamicResource AppBorderColor}"
                    BorderThickness="1"
                    CornerRadius="4">
                    <TreeDataGrid Height="400" Source="{Binding Source}" />
                </Border>
            </StackPanel>

            <StackPanel Grid.Column="1" Spacing="20">
                <Border
                    Background="{Binding IsEditMode, Converter={StaticResource EditModeBackgroundConverter}}"
                    Classes="Card"
                    Padding="15">
                    <StackPanel Spacing="15">
                        <Grid ColumnDefinitions="*, Auto">
                            <TextBlock Classes="h2" Text="{Binding FormTitle}" />
                            <Button
                                Classes="Ghost"
                                Command="{Binding ResetFormCommand}"
                                Content="New Account"
                                Grid.Column="1"
                                IsVisible="{Binding IsEditMode}"
                                Theme="{StaticResource BorderlessButton}" />
                        </Grid>

                        <StackPanel Spacing="5">
                            <TextBlock Classes="form label" Text="Account Type" />
                            <ComboBox
                                HorizontalAlignment="Stretch"
                                ItemsSource="{Binding AccountTypes}"
                                SelectedItem="{Binding SelectedAccountType}" />
                        </StackPanel>

                        <StackPanel Spacing="5">
                            <TextBlock Classes="form label" Text="Parent Account" />
                            <ComboBox
                                HorizontalAlignment="Stretch"
                                ItemsSource="{Binding FilteredParentAccounts}"
                                SelectedItem="{Binding SelectedParentAccount}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Name}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Spacing="5">
                            <TextBlock Classes="form label" Text="Account Code" />
                            <TextBox Text="{Binding AccountCode}" Watermark="Enter code..." />
                        </StackPanel>

                        <StackPanel Spacing="5">
                            <TextBlock Classes="form label" Text="Account Name" />
                            <TextBox Text="{Binding AccountName}" Watermark="Enter name..." />
                        </StackPanel>

                        <StackPanel Spacing="10">
                            <Button
                                Classes="Primary"
                                Command="{Binding AddAccountCommand}"
                                Content="{Binding ActionButtonText}"
                                HorizontalAlignment="Stretch" />
                            <Button
                                Command="{Binding DeleteAccountCommand}"
                                Content="Delete"
                                HorizontalAlignment="Stretch"
                                IsVisible="{Binding SelectedAccount, Converter={x:Static ObjectConverters.IsNotNull}}" />
                        </StackPanel>

                        <TextBlock
                            FontSize="12"
                            Foreground="{DynamicResource SemiRed6}"
                            HorizontalAlignment="Center"
                            IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                            Text="{Binding StatusMessage}"
                            TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </StackPanel>
</UserControl>

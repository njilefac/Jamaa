<UserControl
    d:DesignHeight="600"
    d:DesignWidth="900"
    mc:Ignorable="d"
    x:Class="Jamaa.Desktop.Accounting.ChartOfAccountsPage"
    x:DataType="vm:ChartOfAccountsViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:converters="clr-namespace:Jamaa.Desktop.Services.Converters"
    xmlns:shared="clr-namespace:Jamaa.Desktop.Shared"
    xmlns:vm="clr-namespace:Jamaa.Desktop.Accounting"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <converters:BoolToObjectConverter
            FalseValue="Transparent"
            TrueValue="{StaticResource SystemAccentColorLight3}"
            x:Key="EditModeBackgroundConverter" />
        <converters:BoolToObjectConverter
            FalseValue="True"
            TrueValue="False"
            x:Key="InvertBoolToEnabledConverter" />

        <converters:DecimalToFormattedStringConverter x:Key="DecimalToFormattedStringConverter" />
    </UserControl.Resources>

    <Grid Margin="20" RowDefinitions="Auto,*">

        <TextBlock
            Classes="h1"
            Grid.Row="0"
            Margin="0,0,0,16"
            Text="{Binding PageTitle}" />

        <Grid ColumnDefinitions="*,320" Grid.Row="1">

            <!--  Left: account tree with toolbar  -->
            <DockPanel Grid.Column="0" Margin="0,0,16,0">

                <Grid
                    ColumnDefinitions="*,Auto"
                    DockPanel.Dock="Top"
                    Margin="0,0,0,10">
                    <TextBlock
                        Classes="h2"
                        Text="Accounts"
                        VerticalAlignment="Center" />
                    <Button
                        Classes="Primary"
                        Command="{Binding ResetFormCommand}"
                        Content="+ New Account"
                        Grid.Column="1"
                        IsEnabled="{Binding IsOperationInFlight, Converter={StaticResource InvertBoolToEnabledConverter}}"
                        ToolTip.Tip="Create a new account" />
                </Grid>

                <Border
                    BorderBrush="{DynamicResource AppBorderColor}"
                    BorderThickness="1"
                    ClipToBounds="True"
                    CornerRadius="8">
                    <ScrollViewer>
                        <ItemsControl ItemsSource="{Binding AllAccounts}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:AccountItemViewModel">
                                    <Border
                                        BorderBrush="{DynamicResource AppBorderColor}"
                                        BorderThickness="0,0,0,1"
                                        Padding="12,10">
                                        <Grid ColumnDefinitions="90,*,2*,120,90,120,90,90,90" RowDefinitions="Auto,Auto" RowSpacing="6">
                                            <TextBlock
                                                Classes="form label"
                                                Grid.Column="0"
                                                Text="{Binding Code}" />
                                            <TextBlock
                                                Grid.Column="1"
                                                Text="{Binding TreeName}"
                                                TextTrimming="CharacterEllipsis" />
                                            <TextBlock
                                                Grid.Column="2"
                                                Foreground="{DynamicResource AppTextSecondary}"
                                                Text="{Binding Description}"
                                                TextTrimming="CharacterEllipsis" />
                                            <TextBlock
                                                Grid.Column="3"
                                                Text="{Binding TypeDisplay}" />
                                            <TextBlock
                                                Grid.Column="4"
                                                Text="{Binding ContraAccountDisplay}" />

                                            <TextBox
                                                Grid.Column="5"
                                                HorizontalAlignment="Stretch"
                                                IsReadOnly="{Binding IsOpeningBalanceLocked}"
                                                IsVisible="{Binding IsLeafAccount}"
                                                Watermark="0.00">
                                                <TextBox.Text>
                                                    <Binding
                                                        Mode="TwoWay"
                                                        Path="OpeningBalanceText"
                                                        UpdateSourceTrigger="PropertyChanged" />
                                                </TextBox.Text>
                                                <TextBox.InnerLeftContent>
                                                    <TextBlock
                                                        Margin="8,0,0,0"
                                                        Text="{Binding CurrencySymbol}"
                                                        VerticalAlignment="Center" />
                                                </TextBox.InnerLeftContent>
                                            </TextBox>
                                            <TextBlock
                                                Grid.Column="5"
                                                HorizontalAlignment="Right"
                                                IsVisible="{Binding !IsLeafAccount}"
                                                Text="{Binding OpeningBalanceText}" />
                                            <Button
                                                Classes="Small"
                                                Command="{Binding SaveOpeningBalanceCommand}"
                                                Content="Save"
                                                Grid.Column="6"
                                                IsEnabled="{Binding CanSaveOpeningBalance}"
                                                IsVisible="{Binding CanEditOpeningBalance}" />
                                            <Button
                                                Classes="Small"
                                                Command="{Binding EditCommand}"
                                                Content="Edit"
                                                Grid.Column="7" />
                                            <Button
                                                Classes="Small"
                                                Command="{Binding ToggleActiveCommand}"
                                                Content="{Binding ToggleStateLabel}"
                                                Grid.Column="8"
                                                ToolTip.Tip="{Binding ToggleActiveToolTip}" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>
            </DockPanel>

            <!--  Right: context-aware form  -->
            <Border
                BorderBrush="{DynamicResource AppBorderColor}"
                BorderThickness="1"
                ClipToBounds="True"
                CornerRadius="8"
                Grid.Column="1">
                <Grid RowDefinitions="Auto,Auto,*">

                    <!--  Form header  -->
                    <Grid
                        Background="{Binding IsEditMode, Converter={StaticResource EditModeBackgroundConverter}}"
                        ColumnDefinitions="*,Auto"
                        Grid.Row="0"
                        Margin="16,14,16,14">
                        <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock Classes="h2" Text="{Binding FormTitle}" />
                            <TextBlock
                                FontSize="12"
                                Foreground="{DynamicResource AppTextSecondary}"
                                IsVisible="{Binding IsEditMode}"
                                Text="{Binding SelectedAccount.Name}"
                                TextTrimming="CharacterEllipsis" />
                        </StackPanel>

                    </Grid>

                    <Border
                        Background="{DynamicResource AppDividerColor}"
                        Grid.Row="1"
                        Height="1" />

                    <!--  Form fields  -->
                    <ScrollViewer Grid.Row="2">
                        <StackPanel
                            IsEnabled="{Binding IsOperationInFlight, Converter={StaticResource InvertBoolToEnabledConverter}}"
                            Margin="16"
                            Spacing="14">

                            <StackPanel Spacing="4">
                                <TextBlock Classes="form label" Text="Account Type *" />
                                <ComboBox
                                    HorizontalAlignment="Stretch"
                                    ItemsSource="{Binding AccountTypes}"
                                    SelectedItem="{Binding SelectedAccountType}" />
                            </StackPanel>

                            <StackPanel Spacing="4">
                                <TextBlock Classes="form label" Text="Account Code *" />
                                <TextBox Text="{Binding AccountCode}" Watermark="e.g. 1001" />
                            </StackPanel>

                            <StackPanel Spacing="4">
                                <TextBlock Classes="form label" Text="Account Name *" />
                                <TextBox Text="{Binding AccountName}" Watermark="e.g. Cash and Bank" />
                            </StackPanel>

                            <StackPanel Spacing="4">
                                <TextBlock Classes="form label" Text="Description" />
                                <TextBox
                                    AcceptsReturn="True"
                                    MinHeight="64"
                                    Text="{Binding AccountDescription}"
                                    TextWrapping="Wrap"
                                    Watermark="Optional account description" />
                            </StackPanel>

                            <CheckBox
                                Content="Contra account"
                                IsChecked="{Binding IsContraAccount}" />

                            <StackPanel Spacing="4">
                                <TextBlock Classes="form label" Text="Parent Account" />
                                <TextBlock
                                    FontSize="11"
                                    Foreground="{DynamicResource AppTextSecondary}"
                                    Text="Optional - groups this under another account" />
                                <ComboBox
                                    HorizontalAlignment="Stretch"
                                    ItemsSource="{Binding FilteredParentAccounts}"
                                    SelectedItem="{Binding SelectedParentAccount}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate x:DataType="vm:AccountItemViewModel">
                                            <TextBlock Text="{Binding Name}" />
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </StackPanel>

                            <StackPanel Margin="0,6,0,0" Spacing="8">
                                <Button
                                    Classes="Primary"
                                    Command="{Binding AddAccountCommand}"
                                    Content="{Binding ActionButtonText}"
                                    HorizontalAlignment="Stretch" />
                                <Button
                                    BorderBrush="{DynamicResource ValidationErrorBrush}"
                                    Command="{Binding DeleteAccountCommand}"
                                    Content="Delete Account"
                                    Foreground="{DynamicResource ValidationErrorBrush}"
                                    HorizontalAlignment="Stretch"
                                    IsVisible="{Binding SelectedAccount, Converter={x:Static ObjectConverters.IsNotNull}}"
                                    ToolTip.Tip="{Binding DeleteAccountTooltip}" />
                                <TextBlock
                                    FontSize="11"
                                    Foreground="{DynamicResource AppTextSecondary}"
                                    IsVisible="{Binding HasStatusMessage}"
                                    Text="{Binding StatusMessage}"
                                    TextWrapping="Wrap" />
                            </StackPanel>

                        </StackPanel>
                    </ScrollViewer>

                    <shared:OperationStatusBanner
                        Grid.Row="2"
                        HorizontalAlignment="Stretch"
                        IsActive="{Binding IsOperationInFlight}"
                        Margin="16,0,16,16"
                        Message="Waiting for account confirmation..."
                        VerticalAlignment="Bottom" />
                </Grid>
            </Border>

        </Grid>
    </Grid>
</UserControl>

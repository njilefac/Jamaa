<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:controls="clr-namespace:FluentAvalonia.UI.Controls;assembly=FluentAvalonia"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <controls:FAImageIconSource Source="/Assets/Icons/home/home_outline.png" x:Key="Icons.Home" />
    <controls:FAImageIconSource Source="/Assets/Icons/user/group.png" x:Key="Icons.Members" />
    <controls:FAImageIconSource Source="/Assets/Icons/calendar/calendar_event.png" x:Key="Icons.Calendar" />
    <controls:FAImageIconSource Source="/Assets/Icons/basic/credit_card.png" x:Key="Icons.Accounting" />
    <controls:FAImageIconSource Source="/Assets/Icons/basic/settings.png" x:Key="Icons.Settings" />
    <controls:FAImageIconSource Source="/Assets/Icons/edit/search_small.png" x:Key="Icons.Search" />
    <controls:FAImageIconSource Source="/Assets/Icons/chart/bar_chart.png" x:Key="Icons.Analytics" />
</ResourceDictionary>
{
    "Authentication": {
        "Provider": "ElsaIdentity",
        "OpenIdConnect": {
            "Authority": "https://login.microsoftonline.com/{tenant-id}/v2.0",
            "ClientId": "{client-id}",
            "AuthenticationScopes": [
                "openid",
                "profile",
                "offline_access"
            ],
            "BackendApiScopes": [
                "api://{backend-api-client-id}/elsa-server-api"
            ]
        }
    },
    "Localization": {
        "DefaultCulture": "en-US",
        "SupportedCultures": [
            "en-US"
        ]
    }
}

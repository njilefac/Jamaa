<UserControl
    x:Class="Libota.Desktop.Members.Components.MembersSummaryPane"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:husk="https://github.com/d3ara1n/Huskui.Avalonia"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    HorizontalAlignment="Stretch"
    VerticalAlignment="Top"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <husk:Card
        Padding="4"
        BorderBrush="{StaticResource SystemControlForegroundBaseHighBrush}"
        BorderThickness="2"
        CornerRadius="2">
        <StackPanel Spacing="5">
            <TextBlock
                Margin="4,10,4,10"
                FontSize="14"
                FontWeight="Bold"
                Text="Member Statistics" />
            <husk:Divider Orientation="Horizontal" />
            <Grid
                Margin="10"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                ColumnDefinitions="Auto,Auto"
                RowDefinitions="Auto,Auto,Auto">

                <TextBlock
                    Grid.Row="0"
                    Grid.Column="0"
                    FontSize="12"
                    FontWeight="SemiBold"
                    Text="Total Members:" />
                <TextBlock
                    Grid.Row="0"
                    Grid.Column="1"
                    FontSize="12"
                    Text="{Binding TotalMembersCount}" />
                <TextBlock
                    Grid.Row="1"
                    Grid.Column="0"
                    FontSize="12"
                    FontWeight="SemiBold"
                    Text="Female Members:" />
                <TextBlock
                    Grid.Row="1"
                    Grid.Column="1"
                    FontSize="12"
                    Text="{Binding FemaleMembersCount}" />
                <TextBlock
                    Grid.Row="2"
                    Grid.Column="0"
                    FontSize="12"
                    FontWeight="SemiBold"
                    Text="Male Members:" />
                <TextBlock
                    Grid.Row="2"
                    Grid.Column="1"
                    FontSize="12"
                    Text="{Binding MaleMembersCount}" />
            </Grid>
        </StackPanel>
    </husk:Card>
</UserControl>

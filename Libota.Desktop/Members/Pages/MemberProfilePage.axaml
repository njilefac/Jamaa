<UserControl
    x:Class="Libota.Desktop.Members.Pages.MemberProfilePage"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:pages="clr-namespace:Libota.Desktop.Members.Pages"
    d:DesignHeight="450"
    d:DesignWidth="800"
    x:DataType="pages:MemberProfileViewModel"
    mc:Ignorable="d"
    >
    <UserControl.Styles>
        <Style Selector="DockPanel &gt; Border">
            <Setter Property="Margin" Value="20" />
            <Setter Property="CornerRadius" Value="5" />
        </Style>
    </UserControl.Styles>
    <DockPanel>
        <Border>
            <StackPanel>
                <Grid
                    Classes="page form"
                    ColumnDefinitions="Auto,Auto"
                    RowDefinitions="Auto,Auto,Auto,Auto"
                    >
                    <TextBlock
                        Grid.Row="0"
                        Grid.Column="0"
                        Classes="form label"
                        Text="First Name:"
                        />
                    <TextBox
                        Grid.Row="0"
                        Grid.Column="1"
                        Classes="form field"
                        Text="{Binding FirstName}"
                        />
                    <TextBlock
                        Grid.Row="1"
                        Grid.Column="0"
                        Classes="form label"
                        Text="Middle Name:"
                        />
                    <TextBox
                        Grid.Row="1"
                        Grid.Column="1"
                        Classes="form field"
                        Text="{Binding MiddleName}"
                        />
                    <TextBlock
                        Grid.Row="2"
                        Grid.Column="0"
                        Classes="form label"
                        Text="Last Name:"
                        />
                    <TextBox
                        Grid.Row="2"
                        Grid.Column="1"
                        Classes="form field"
                        Text="{Binding LastName}"
                        />
                    <TextBlock
                        Grid.Row="3"
                        Grid.Column="0"
                        Classes="form label"
                        Text="Gender:"
                        />
                    <ComboBox
                        Grid.Row="3"
                        Grid.Column="1"
                        Classes="form field"
                        ItemsSource="{Binding Genders}"
                        SelectedItem="{Binding Gender}"
                        >
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </Grid>
            </StackPanel>
        </Border>
        <Border>
            <StackPanel>
                <Grid
                    Classes="page form"
                    ColumnDefinitions="Auto,Auto"
                    RowDefinitions="Auto,Auto,Auto"
                    >
                    <TextBlock
                        Grid.Row="0"
                        Grid.Column="0"
                        Classes="form label"
                        Text="Member Since:"
                        />
                    <CalendarDatePicker
                        Grid.Row="0"
                        Grid.Column="1"
                        Classes="form field"
                        SelectedDate="{Binding Registration.StartDate}"
                        />
                    <TextBlock
                        Grid.Row="1"
                        Grid.Column="0"
                        Classes="form label"
                        Text="Membership Status:"
                        />
                    <ComboBox
                        Grid.Row="1"
                        Grid.Column="1"
                        Classes="form field"
                        ItemsSource="{Binding RegistrationStatuses}"
                        SelectedItem="{Binding Registration.Status}"
                        >
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <TextBlock
                        Grid.Row="2"
                        Grid.Column="0"
                        Classes="form label"
                        Text="Membership Type:"
                        />
                    <ComboBox
                        Grid.Row="2"
                        Grid.Column="1"
                        Classes="form field"
                        ItemsSource="{Binding MembershipTypes}"
                        SelectedItem="{Binding Registration.MembershipType}"
                        >
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </Grid>
            </StackPanel>
        </Border>
    </DockPanel>
</UserControl>
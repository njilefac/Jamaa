<UserControl
    x:Class="Libota.Desktop.Setup.CreateOrganisationScreen"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    HorizontalAlignment="Center"
    VerticalAlignment="Center"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">

    <StackPanel>
        <TextBlock
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Classes="page title"
            Text="Create Organisation" />
        <Grid ColumnDefinitions="Auto, Auto" RowDefinitions="Auto,Auto,Auto">
            <TextBlock
                Grid.Row="0"
                Grid.Column="0"
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                Classes="form label"
                Text="Organisation Name:" />
            <TextBox
                x:Name="OrganisationNameField"
                Grid.Row="0"
                Grid.Column="1"
                Classes="form field"
                Text="{Binding Mode=TwoWay, Path=Name, UpdateSourceTrigger=PropertyChanged}" />
            <TextBlock
                Grid.Row="1"
                Grid.Column="0"
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                Classes="form label"
                Text="Description:" />
            <TextBox
                Grid.Row="1"
                Grid.Column="1"
                Classes="form field"
                Text="{Binding Description}" />
            <Button
                Grid.Row="2"
                Grid.Column="1"
                HorizontalAlignment="Right"
                Command="{Binding CreateOrganisationCommand}"
                Content="Create"
                IsDefault="True" />
        </Grid>
    </StackPanel>
</UserControl>

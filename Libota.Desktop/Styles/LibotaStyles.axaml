<Styles
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:husk="https://github.com/d3ara1n/Huskui.Avalonia">
    <Design.PreviewWith>
        <Border Padding="20">
            <!--  Add Controls for Previewer Here  -->
        </Border>
    </Design.PreviewWith>

    <Style Selector="HeaderedContentControl">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate>
                    <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,*">
                        <Border
                            Margin="5,0,0,0"
                            Padding="5,0,5,0"
                            Background="White"
                            ZIndex="1">
                            <TextBlock FontWeight="Bold" Text="{TemplateBinding Header}" />
                        </Border>
                        <Border
                            Grid.Row="0"
                            Grid.RowSpan="2"
                            Grid.Column="0"
                            Grid.ColumnSpan="2"
                            Margin="0,10,0,0"
                            BorderBrush="{TemplateBinding Background}"
                            BorderThickness="1">
                            <ContentPresenter Content="{TemplateBinding Content}" />
                        </Border>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style Selector="TextBlock.page.title">
        <Setter Property="FontSize" Value="24" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Padding" Value="5,5,5,50" />
    </Style>
    <Style Selector="TextBlock.form.label">
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
    <Style Selector="TextBox.form.field">
        <Setter Property="Width" Value="250" />
        <Setter Property="Margin" Value="10,5,0,10" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="FontSize" Value="16" />
    </Style>
    <Style Selector="ComboBox.form.field">
        <Setter Property="Width" Value="250" />
        <Setter Property="Margin" Value="10,5,0,10" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="FontWeight" Value="DemiBold" />
    </Style>
    <Style Selector="CalendarDatePicker.form.field">
        <Setter Property="Background" Value="{StaticResource CalendarDatePickerBackground}" />
        <Setter Property="Width" Value="250" />
        <Setter Property="Margin" Value="10,5,0,5" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="FontSize" Value="16" />
    </Style>
    <Style Selector="TextBox.secret">
        <Setter Property="PasswordChar" Value="*" />
        <Setter Property="RevealPassword" Value="False" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Width" Value="250" />
    </Style>
    <Style Selector="TextBlock.page.box.header">
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="FontSize" Value="14" />
    </Style>
    <Style Selector="Border.page.box">
        <Setter Property="Margin" Value="15,10,15,10" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="VerticalAlignment" Value="Stretch" />
        <Setter Property="Background" Value="LightGray" />
        <Setter Property="Padding" Value="5" />
    </Style>
    <Style Selector="husk|Card.memberlist.member-card:pointerover">
        <Setter Property="BorderBrush" Value="{StaticResource AccentButtonBorderBrushPointerOver}" />
        <Setter Property="Background" Value="{StaticResource ControlStrokeColorOnAccentDefault}" />
    </Style>
    <Style Selector="husk|Card.member-card:focus">
        <Setter Property="BorderThickness" Value="4" />
        <Setter Property="Background" Value="{StaticResource AccentButtonBackgroundPressed}" />
    </Style>
    <Style Selector="husk|Divider.member-card">
        <Setter Property="Margin" Value="8" />
        <Setter Property="Height" Value="2" />
        <Setter Property="Width" Value="280" />
        <Setter Property="Orientation" Value="Horizontal" />
    </Style>
    <Style Selector="husk|Card.memberlist.member-card">
        <Setter Property="Width" Value="300" />
        <Setter Property="Height" Value="200" />
        <Setter Property="Padding" Value="8" />
        <Setter Property="CornerRadius" Value="6" />
    </Style>
    <Style Selector="Label.member-card.title">
        <Setter Property="FontSize" Value="20" />
    </Style>
</Styles>

<Styles
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:husk="https://github.com/d3ara1n/Huskui.Avalonia"
    >
    <Design.PreviewWith>
        <Border Padding="20">
            <!--  Add Controls for Previewer Here  -->
        </Border>
    </Design.PreviewWith>
    <Style Selector="husk|Card:pointerover">
        <Setter Property="BorderBrush" Value="{StaticResource AccentButtonBorderBrushPointerOver}" />
        <Setter Property="BorderThickness" Value="2" />
        <Setter Property="Background" Value="{StaticResource HighlightColor}" />
    </Style>
    <Style Selector="husk|Card:pressed">
        <Setter Property="BorderThickness" Value="4" />
        <Setter Property="Background" Value="{StaticResource AccentButtonBackgroundPressed}" />
    </Style>
    <Style Selector="husk|Divider">
        <Setter Property="Margin" Value="2,4" />
        <Setter Property="Height" Value="2" />
    </Style>
    <Style Selector="husk|Card.memberlist.card">
        <Setter Property="Width" Value="250" />
        <Setter Property="Height" Value="150" />
        <Setter Property="Padding" Value="2" />
        <Setter Property="CornerRadius" Value="8" />
    </Style>
</Styles>

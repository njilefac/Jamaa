<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sty="using:FluentAvalonia.Styling"
             x:Class="Libota.Desktop.App"
             Name="Libota Desktop">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="/Assets/Resources/Icons.axaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>

    <Application.Styles>
        <FluentTheme Mode="Light" />
        <sty:FluentAvaloniaTheme />
        <StyleInclude Source="avares://Aura.UI/AuraUI.xaml" />
        <StyleInclude Source="avares://Avalonia.Themes.Fluent/Accents/BaseLight.xaml" />
        <StyleInclude Source="avares://Avalonia.Themes.Default/Accents/BaseLight.xaml" />
        <StyleInclude Source="avares://Avalonia.Themes.Default/DefaultTheme.xaml" />
        <StyleInclude Source="/Assets/Styles/FormStyles.axaml" />
        <StyleInclude Source="/Assets/Styles/PageStyles.axaml" />
        <StyleInclude Source="/Assets/Styles/ControlStyles.axaml" />
    </Application.Styles>

</Application>
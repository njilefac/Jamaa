<Application
    x:Class="Libota.Desktop.App"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:members-View-Models="clr-namespace:Libota.Desktop.ViewModels.Members"
    xmlns:members-Views="clr-namespace:Libota.Desktop.Views.Members"
    xmlns:security-View-Models="clr-namespace:Libota.Desktop.ViewModels.Security"
    xmlns:security-Views="clr-namespace:Libota.Desktop.Views.Security"
    xmlns:setup-View-Models="clr-namespace:Libota.Desktop.ViewModels.Setup"
    xmlns:setup-Views="clr-namespace:Libota.Desktop.Views.Setup"
    xmlns:shared-View-Models="clr-namespace:Libota.Desktop.ViewModels.Shared"
    xmlns:shared-Views="clr-namespace:Libota.Desktop.Views.Shared"
    xmlns:sty="using:FluentAvalonia.Styling"
    Name="Libota Desktop"
    RequestedThemeVariant="Dark">

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="/Assets/Resources/Icons.axaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>

    <Application.Styles>
        <sty:FluentAvaloniaTheme />
        <StyleInclude Source="/Assets/Styles/FormStyles.axaml" />
        <StyleInclude Source="/Assets/Styles/PageStyles.axaml" />
        <StyleInclude Source="/Assets/Styles/ControlStyles.axaml" />
    </Application.Styles>

    <Application.DataTemplates>
        <DataTemplate DataType="{x:Type shared-View-Models:MainWindowViewModel}">
            <shared-Views:MainWindow />
        </DataTemplate>
        <DataTemplate DataType="{x:Type shared-View-Models:MainMenuViewModel}">
            <shared-Views:MainMenu />
        </DataTemplate>
        <DataTemplate DataType="{x:Type shared-View-Models:DashboardViewModel}">
            <shared-Views:Dashboard />
        </DataTemplate>
        <DataTemplate DataType="{x:Type setup-View-Models:CreateOrganisationViewModel}">
            <setup-Views:CreateOrganisationScreen />
        </DataTemplate>
        <DataTemplate DataType="{x:Type setup-View-Models:CreateSuperUserViewModel}">
            <setup-Views:CreateSuperUserScreen />
        </DataTemplate>
        <DataTemplate DataType="{x:Type security-View-Models:LoginScreenViewModel}">
            <security-Views:LoginScreen />
        </DataTemplate>
        <DataTemplate DataType="{x:Type members-View-Models:MemberManagementScreenViewModel}">
            <members-Views:MemberManagementScreen />
        </DataTemplate>
        <DataTemplate DataType="{x:Type members-View-Models:MemberOverviewPageViewModel}">
            <members-Views:MembersOverviewPage />
        </DataTemplate>
    </Application.DataTemplates>
</Application>
<UserControl
    x:Class="Libota.Desktop.Views.Shared.Dashboard"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:FluentAvalonia.UI.Controls;assembly=FluentAvalonia"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:navigation="clr-namespace:Libota.Desktop.ViewModels.Navigation"
    xmlns:services="clr-namespace:Libota.Desktop.Services"
    xmlns:shared="clr-namespace:Libota.Desktop.ViewModels.Shared"
    HorizontalAlignment="Stretch"
    VerticalAlignment="Stretch"
    HorizontalContentAlignment="Stretch"
    VerticalContentAlignment="Stretch"
    d:DesignHeight="450"
    d:DesignWidth="800"
    x:DataType="shared:DashboardViewModel"
    mc:Ignorable="d">

    <UserControl.Resources>
        <services:LibotaIconSourceConverter x:Key="IconSourceConverter" />
    </UserControl.Resources>

    <controls:NavigationView
        VerticalAlignment="Stretch"
        Content="{Binding ActiveContent}"
        Header="{Binding $self.SelectedItem.Title}"
        MenuItemsSource="{Binding MenuItems}"
        PaneDisplayMode="Auto"
        PaneTitle="Modules"
        SelectedItem="{Binding SelectedItem, Mode=TwoWay}">

        <controls:NavigationView.MenuItemTemplate>
            <DataTemplate x:DataType="navigation:NavigationItemViewModel">
                <controls:NavigationViewItem
                    Content="{Binding Title}"
                    IconSource="{Binding Icon, Converter={StaticResource IconSourceConverter}}"
                    Tag="{Binding TargetRoute}" />
            </DataTemplate>
        </controls:NavigationView.MenuItemTemplate>
        <controls:NavigationView.HeaderTemplate>
            <DataTemplate>
                <TextBlock
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Top"
                    FontSize="22"
                    FontWeight="Bold"
                    Text="{Binding}"
                    TextAlignment="Center" />
            </DataTemplate>
        </controls:NavigationView.HeaderTemplate>
    </controls:NavigationView>
</UserControl>
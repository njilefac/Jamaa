<Window
    Background="Transparent"
    Icon="/Assets/Icons/avalonia-logo.ico"
    ShowActivated="True"
    Title="{Binding ApplicationTitle}"
    TransparencyLevelHint="Blur, Mica"
    WindowStartupLocation="CenterScreen"
    WindowState="Maximized"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d"
    x:Class="Libota.Desktop.Views.Shared.MainWindow"
    x:DataType="shared:MainWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:shared="clr-namespace:Libota.Desktop.Views.Shared"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid ColumnDefinitions="*" RowDefinitions="Auto,*,35">
        <shared:MainMenu Content="{Binding MainMenuViewModel}" Grid.Row="0" />
        <Panel Grid.Row="1">
            <ContentControl
                Content="{Binding CurrentViewModel}"
                HorizontalContentAlignment="Stretch"
                VerticalContentAlignment="Stretch"
                x:Name="ContentContainer" />
        </Panel>
        <Panel
            Background="gray"
            Grid.Row="2"
            Opacity="0.2" />
    </Grid>
</Window>
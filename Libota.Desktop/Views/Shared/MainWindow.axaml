<Window
    x:Class="Libota.Desktop.Views.Shared.MainWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:shared="clr-namespace:Libota.Desktop.Views.Shared"
    Title="{Binding ApplicationTitle}"
    d:DesignHeight="450"
    d:DesignWidth="800"
    x:DataType="shared:MainWindow"
    Background="Transparent"
    Icon="/Assets/Icons/avalonia-logo.ico"
    ShowActivated="True"
    TransparencyLevelHint="Blur, Mica"
    WindowStartupLocation="CenterScreen"
    WindowState="Maximized"
    mc:Ignorable="d">
    <Grid ColumnDefinitions="*" RowDefinitions="Auto,*,35">
        <shared:MainMenu Grid.Row="0" Content="{Binding MainMenuViewModel}" />
        <Panel Grid.Row="1">
            <ContentControl
                x:Name="ContentContainer"
                HorizontalContentAlignment="Stretch"
                VerticalContentAlignment="Stretch"
                Content="{Binding CurrentViewModel}" />
        </Panel>
        <Panel
            Grid.Row="2"
            Background="gray"
            Opacity="0.2" />
    </Grid>
</Window>
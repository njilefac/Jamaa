<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:members="clr-namespace:Libota.Desktop.Views.Members"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="Libota.Desktop.Views.Members.MembersList">
    <Grid RowDefinitions="60,*">
        <TextBox Grid.Row="0" Watermark="Search for members"
                 VerticalAlignment="Top"
                 HorizontalAlignment="Center"
                 Text="{Binding SearchTerm}"
                 MinWidth="800" />
        <ScrollViewer Grid.Row="1" HorizontalContentAlignment="Stretch" Height="{Binding $parent[Window].ClientSize.Height}">
            <ItemsRepeater ItemsSource="{Binding Members}">
                <ItemsRepeater.Layout>
                    <WrapLayout HorizontalSpacing="15" Orientation="Horizontal" VerticalSpacing="15" />
                </ItemsRepeater.Layout>
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate>
                        <members:MemberCard />
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>
        </ScrollViewer>
    </Grid>

</UserControl>
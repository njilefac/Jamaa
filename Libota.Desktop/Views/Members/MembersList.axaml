<UserControl
    x:Class="Libota.Desktop.Views.Members.MembersList"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:FluentAvalonia.UI.Controls;assembly=FluentAvalonia"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:data="clr-namespace:Libota.Data.Models.Members;assembly=Libota.Data"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:members="clr-namespace:Libota.Desktop.Views.Members"
    HorizontalAlignment="Stretch"
    VerticalAlignment="Stretch"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">

    <UserControl.KeyBindings>
        <KeyBinding Gesture="Ctrl+A" />
    </UserControl.KeyBindings>
    <Panel>
        <Grid RowDefinitions="60,*,60">
            <TextBox
                Grid.Row="0"
                Width="700"
                Margin="0,10,0,0"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                HorizontalContentAlignment="Center"
                VerticalContentAlignment="Center"
                CornerRadius="8"
                FontSize="14"
                Text="{Binding SearchTerm}"
                Watermark="Find members">
                <TextBox.InnerLeftContent>
                    <Image
                        Width="40"
                        Height="40"
                        Source="avares://Libota/Assets/Icons/edit/search_small.png" />
                </TextBox.InnerLeftContent>
            </TextBox>
            <ScrollViewer
                Grid.Row="1"
                Margin="5"
                Padding="30,0,30,0"
                AllowAutoHide="True"
                Background="{StaticResource SystemListLowColor}"
                HorizontalScrollBarVisibility="Disabled"
                VerticalScrollBarVisibility="Auto">
                <ItemsRepeater
                    HorizontalAlignment="Center"
                    VerticalAlignment="Top"
                    ItemsSource="{Binding Members}">
                    <ItemsRepeater.Layout>
                        <WrapLayout Orientation="Horizontal" />
                    </ItemsRepeater.Layout>
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate x:DataType="data:MemberData">
                            <members:MemberCard />
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
            </ScrollViewer>
            <members:MemberActionsPane Grid.Row="2" />
        </Grid>
        <controls:ContentDialog
            x:Name="AddMemberDialog"
            Title="Register New Member"
            IsVisible="False"
            PrimaryButtonText="Register Member"
            SecondaryButtonText="Cancel">
            <StackPanel>
                <ExperimentalAcrylicBorder IsHitTestVisible="False">
                    <ExperimentalAcrylicBorder.Material>
                        <ExperimentalAcrylicMaterial
                            BackgroundSource="Digger"
                            MaterialOpacity="0.65"
                            TintColor="Black"
                            TintOpacity="0.6" />
                    </ExperimentalAcrylicBorder.Material>
                </ExperimentalAcrylicBorder>
                <Border Padding="8" Classes="box">
                    <Grid ColumnDefinitions="Auto,Auto" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto">
                        <TextBlock
                            Grid.Row="0"
                            Grid.Column="0"
                            Classes="form label"
                            Text="First Name" />
                        <TextBox
                            x:Name="FirstNameField"
                            Grid.Row="0"
                            Grid.Column="1"
                            Classes="form field"
                            Text="{Binding FirstName}" />

                        <TextBlock
                            Grid.Row="1"
                            Grid.Column="0"
                            Classes="form label"
                            Text="Middle Name" />
                        <TextBox
                            Grid.Row="1"
                            Grid.Column="1"
                            Classes="form field"
                            Text="{Binding MiddleName}" />

                        <TextBlock
                            Grid.Row="2"
                            Grid.Column="0"
                            Classes="form label"
                            Text="Last Name" />
                        <TextBox
                            Grid.Row="2"
                            Grid.Column="1"
                            Classes="form field"
                            Text="{Binding LastName}" />

                        <TextBlock
                            Grid.Row="3"
                            Grid.Column="0"
                            Classes="form label"
                            Text="Gender" />
                        <ComboBox
                            Grid.Row="3"
                            Grid.Column="1"
                            Classes="form field"
                            ItemsSource="{Binding GenderChoices}"
                            SelectedItem="{Binding Mode=TwoWay, Path=SelectedGender}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <TextBlock
                            Grid.Row="4"
                            Grid.Column="0"
                            Classes="form label"
                            Text="Member Since" />
                        <CalendarDatePicker
                            Grid.Row="4"
                            Grid.Column="1"
                            Classes="form field"
                            CustomDateFormatString="dd.MMM.yyyy"
                            DisplayDate="{Binding RegistrationBegin, Mode=TwoWay}"
                            SelectedDate="{Binding RegistrationBegin}"
                            SelectedDateFormat="Custom" />
                    </Grid>
                </Border>
            </StackPanel>
        </controls:ContentDialog>
    </Panel>
</UserControl>
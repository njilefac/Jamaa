<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:data="clr-namespace:Libota.Data.Models.Members;assembly=Libota.Data"
             xmlns:members="clr-namespace:Libota.Desktop.Views.Members"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="Libota.Desktop.Views.Members.MembersList">
    <Grid RowDefinitions="60,*">
        <TextBox Grid.Row="0" Watermark="Find members"
                 VerticalAlignment="Top"
                 HorizontalAlignment="Center"
                 Text="{Binding SearchTerm}"
                 HorizontalContentAlignment="Center"
                 VerticalContentAlignment="Center"
                 Width="700"
                 FontSize="14"
                 CornerRadius="8">
            <TextBox.InnerRightContent>
                <Image Source="../../Assets/Icons/edit/ search_small.png" Width="40" Height="40" />
            </TextBox.InnerRightContent>
        </TextBox>
        <ListBox Grid.Row="1" ItemsSource="{Binding Members}" Margin="10">
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel Orientation="Horizontal"/>
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
            <ListBox.ItemTemplate>
                <DataTemplate x:DataType="data:MemberData">
                    <members:MemberCard />
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</UserControl>
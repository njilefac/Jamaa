<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:members="clr-namespace:Libota.Data.Models.Members;assembly=Libota.Data"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="Libota.Desktop.Views.Members.MemberCard"
             x:DataType="members:MemberData"
             Margin="0"
             Width="220" 
             Height="170" 
             CornerRadius="10" 
             BorderThickness="1" 
             Padding="2" 
             ClipToBounds="True">

    <Grid RowDefinitions="Auto,Auto,*" ColumnDefinitions="Auto,Auto">
        <Label Content="{Binding FirstName}" Grid.Row="0" Grid.Column="0" FontWeight="Bold" FontSize="14"/>
        <Label Content="{Binding LastName}" Grid.Row="0" Grid.Column="1" FontWeight="Bold" FontSize="14"/>
        <Label Content="{Binding Gender}" Grid.Row="2" Grid.Column="0" />
    </Grid>
</UserControl>
<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="Libota.Desktop.Views.Members.MemberCard">
    <Panel Width="200">
        <Panel>
            <StackPanel>
                <TextBlock Text="{Binding FirstName}" />
                <TextBlock Text="{Binding LastName}" />
            </StackPanel>
        </Panel>
        <StackPanel VerticalAlignment="Bottom">
            <TextBlock Text="{Binding Path=Registration.StartDate.Date}" />
            <TextBlock Text="{Binding Path=Registration.MembershipType}" />
            <TextBlock Text="{Binding Path=Registration.Status}" />
        </StackPanel>
        <Interaction.Behaviors>
            <EventTriggerBehavior EventName="DoubleTapped" SourceObject="{Binding $parent[Panel]}">
                <InvokeCommandAction CommandParameter="{Binding}">
                    <InvokeCommandAction.Command>
                        <Binding Path="$parent[members:MembersList].DataContext?.ShowMemberDetails" />
                    </InvokeCommandAction.Command>
                </InvokeCommandAction>
            </EventTriggerBehavior>
        </Interaction.Behaviors>
    </Panel>
</UserControl>
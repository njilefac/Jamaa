<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:members="clr-namespace:Libota.Desktop.Views.Members"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="Libota.Desktop.Views.Members.MemberManagementScreen">
    <AuraTabView HorizontalAlignment="Stretch" VerticalAlignment="Stretch" AdderButtonIsVisible="False">
        <AuraTabItem Header="Overview" IsClosable="False">
            <members:MembersOverviewPage/>
        </AuraTabItem>
    </AuraTabView>
</UserControl>
<UserControl
    x:Class="Libota.Desktop.Views.Members.MemberRegistrationDialog"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:FluentAvalonia.UI.Controls;assembly=FluentAvalonia"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Width="850"
    Height="750"
    HorizontalContentAlignment="Stretch"
    VerticalContentAlignment="Stretch"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <controls:ContentDialog
        x:Name="AddMemberDialog"
        Title="Register New Member"
        PrimaryButtonText="Register Member"
        SecondaryButtonText="Cancel">
        <StackPanel>
            <ExperimentalAcrylicBorder IsHitTestVisible="False">
                <ExperimentalAcrylicBorder.Material>
                    <ExperimentalAcrylicMaterial
                        BackgroundSource="Digger"
                        MaterialOpacity="0.65"
                        TintColor="Black"
                        TintOpacity="0.6" />
                </ExperimentalAcrylicBorder.Material>
            </ExperimentalAcrylicBorder>
            <Border Padding="8" Classes="box">
                <Grid ColumnDefinitions="Auto,Auto" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto">
                    <TextBlock
                        Grid.Row="0"
                        Grid.Column="0"
                        Classes="form label"
                        Text="First Name" />
                    <TextBox
                        x:Name="FirstNameField"
                        Grid.Row="0"
                        Grid.Column="1"
                        Classes="form field"
                        Text="{Binding FirstName}" />

                    <TextBlock
                        Grid.Row="1"
                        Grid.Column="0"
                        Classes="form label"
                        Text="Middle Name" />
                    <TextBox
                        Grid.Row="1"
                        Grid.Column="1"
                        Classes="form field"
                        Text="{Binding MiddleName}" />

                    <TextBlock
                        Grid.Row="2"
                        Grid.Column="0"
                        Classes="form label"
                        Text="Last Name" />
                    <TextBox
                        Grid.Row="2"
                        Grid.Column="1"
                        Classes="form field"
                        Text="{Binding LastName}" />

                    <TextBlock
                        Grid.Row="3"
                        Grid.Column="0"
                        Classes="form label"
                        Text="Gender" />
                    <ComboBox
                        Grid.Row="3"
                        Grid.Column="1"
                        Classes="form field"
                        ItemsSource="{Binding GenderChoices}"
                        SelectedItem="{Binding Mode=TwoWay, Path=SelectedGender}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <TextBlock
                        Grid.Row="4"
                        Grid.Column="0"
                        Classes="form label"
                        Text="Member Since" />
                    <CalendarDatePicker
                        Grid.Row="4"
                        Grid.Column="1"
                        Classes="form field"
                        CustomDateFormatString="dd.MMM.yyyy"
                        DisplayDate="{Binding RegistrationBegin, Mode=TwoWay}"
                        SelectedDate="{Binding RegistrationBegin}"
                        SelectedDateFormat="Custom" />
                </Grid>
            </Border>
        </StackPanel>
    </controls:ContentDialog>
</UserControl>
<UserControl
    x:Class="Libota.Desktop.Views.Members.GlobalMemberStatisticsPane"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <Grid
        Margin="10"
        HorizontalAlignment="Stretch"
        VerticalAlignment="Stretch"
        ColumnDefinitions="Auto,Auto"
        RowDefinitions="Auto,Auto,Auto,Auto">
        <TextBlock
            Grid.Row="0"
            Grid.ColumnSpan="2"
            FontSize="24"
            FontWeight="Bold"
            Text="Member Statistics" />
        <TextBlock
            Grid.Row="1"
            Grid.Column="0"
            FontSize="18"
            FontWeight="SemiBold"
            Text="Total Members:" />
        <TextBlock
            Grid.Row="1"
            Grid.Column="1"
            FontSize="16"
            Text="{Binding TotalMembersCount}" />
        <TextBlock
            Grid.Row="2"
            Grid.Column="0"
            FontSize="18"
            FontWeight="SemiBold"
            Text="Female Members:" />
        <TextBlock
            Grid.Row="2"
            Grid.Column="1"
            FontSize="16"
            Text="{Binding FemaleMembersCount}" />
        <TextBlock
            Grid.Row="3"
            Grid.Column="0"
            FontSize="18"
            FontWeight="SemiBold"
            Text="Male Members:" />
        <TextBlock
            Grid.Row="3"
            Grid.Column="1"
            FontSize="16"
            Text="{Binding MaleMembersCount}" />
    </Grid>
</UserControl>

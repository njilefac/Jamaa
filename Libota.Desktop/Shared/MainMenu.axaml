<UserControl
    x:Class="Libota.Desktop.Shared.MainMenu"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">

    <Menu DockPanel.Dock="Top">
        <MenuItem Header="File">
            <MenuItem Header="Import">
                <MenuItem Header="Members" IsSubMenuOpen="True" />
                <MenuItem Header="Financial Transactions" IsSubMenuOpen="True" />
            </MenuItem>
            <Separator Foreground="DarkGray" />
            <MenuItem Command="{Binding LogoutCommand}" Header="Logout" />
            <Separator Foreground="DarkGray" />
            <MenuItem Command="{Binding ExitApplicationCommand}" Header="Exit" />
        </MenuItem>
        <MenuItem Header="Edit">
            <MenuItem Header="Copy" />
        </MenuItem>
    </Menu>

</UserControl>
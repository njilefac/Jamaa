<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="clr-namespace:FluentAvalonia.UI.Controls;assembly=FluentAvalonia">
    <controls:ImageIconSource x:Key="Icons.Home"  Source="/Assets/Icons/home/ home_outline.png"/>
    <controls:ImageIconSource x:Key="Icons.Members"  Source="/Assets/Icons/user/group.png"/>
    <controls:ImageIconSource x:Key="Icons.Calendar" Source="/Assets/Icons/calendar/calendar_event.png"/>
    <controls:ImageIconSource x:Key="Icons.Finances" Source="/Assets/Icons/basic/credit_card.png"/>
    <controls:ImageIconSource x:Key="Icons.Settings" Source="/Assets/Icons/basic/settings.png"/>
</ResourceDictionary>

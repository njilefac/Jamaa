<Styles xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Style Selector="TextBlock.page.title">
        <Setter Property="FontSize" Value="24" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Padding" Value="5,5,5,50" />
    </Style>
    <Style Selector="TextBlock.form.label">
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
    <Style Selector="TextBox.form.field">
        <Setter Property="Width" Value="250" />
        <Setter Property="Margin" Value="10,5,0,10" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="FontSize" Value="16" />
    </Style>
    <Style Selector="ComboBox.form.field">
        <Setter Property="Background" Value="White" />
        <Setter Property="Foreground" Value="DimGray" />
        <Setter Property="Width" Value="250" />
        <Setter Property="Margin" Value="10,5,0,10" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="FontWeight" Value="DemiBold" />
    </Style>
    <Style Selector="CalendarDatePicker.form.field">
        <Setter Property="Background" Value="White" />
        <Setter Property="Width" Value="250" />
        <Setter Property="Margin" Value="10,5,0,5" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="FontSize" Value="16" />
    </Style>
    <Style Selector="TextBox.secret">
        <Setter Property="PasswordChar" Value="*" />
        <Setter Property="RevealPassword" Value="False" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Width" Value="250" />
    </Style>
</Styles>